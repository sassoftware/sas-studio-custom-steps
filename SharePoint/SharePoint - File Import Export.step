{"creationTimeStamp":"2026-06-02T22:03:13.007667Z","createdBy":"Mayur.Jadhav@posten.no","modifiedTimeStamp":"2026-06-02T22:22:02.259225Z","modifiedBy":"Mayur.Jadhav@posten.no","id":"72768150-3f6b-4095-bcae-05018c617d63","name":"0601SharePoint - File Import Export.step","displayName":"0601SharePoint - File Import Export.step","localDisplayName":"0601SharePoint - File Import Export.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63/copy","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","uri":"/dataFlows/steps/72768150-3f6b-4095-bcae-05018c617d63","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"inputtable1","displayName":"inputtable1","localDisplayName":"inputtable1","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table"}],"outputPorts":[{"name":"outputtable1","displayName":"outputtable1","localDisplayName":"outputtable1","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"SharePoint Token\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"in_token\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Personal SharePoint token file\",\n\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/token.json\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Import/Export files\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"action\",\n\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\"label\": \"Select Action:\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Import\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Export\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"(no value)\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Import Files from SharePoint:\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$action\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Import\"\n\t\t\t\t\t],\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$action\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Import\"\n\t\t\t\t\t],\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sp_hostname\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint hostname:\",\n\t\t\t\t\t\t\t\"placeholder\": \"your.sharepoint.com\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sitepath\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint site path:\",\n\t\t\t\t\t\t\t\"placeholder\": \"/teams/<my SharePoint site name>\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"drivename\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint drive name:\",\n\t\t\t\t\t\t\t\"placeholder\": \"Documents\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"spfolderpath\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint folder path:\",\n\t\t\t\t\t\t\t\"placeholder\": \"/Users/<userid>\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"file_name\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"File Name (add multiple files as: test1.txt, test2.txt; use file extension like .txt or .xlsx to read all files):\",\n\t\t\t\t\t\t\t\"placeholder\": \"test.txt\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"outputfolder\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"Output folder:\",\n\t\t\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/files\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section2\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Export Files to SharePoint/OneDrive:\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$action\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Export\"\n\t\t\t\t\t],\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$action\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Export\"\n\t\t\t\t\t],\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sp_hostname_1\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint hostname\",\n\t\t\t\t\t\t\t\"placeholder\": \"your.sharepoint.com\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sitepath_1\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint sitepath\",\n\t\t\t\t\t\t\t\"placeholder\": \"/teams/<my SharePoint site name>\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"drivename_1\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint drive name\",\n\t\t\t\t\t\t\t\"placeholder\": \"Documents\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"spfolderpath_1\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint folder path\",\n\t\t\t\t\t\t\t\"placeholder\": \"/Users/<userid>\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 1\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"filetoexport\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"Select file to export\",\n\t\t\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/files/test.txt\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section3\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Run this Custom Step\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"inputtable1\",\n\t\t\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\t\t\"label\": \"Input table\",\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"outputtable1\",\n\t\t\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\t\t\"label\": \"Output table\",\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page3\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"Custome Step to export or import files from/to SharePoint/OneDrive.\\n\\n\\n\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"in_token\": \"\",\n\t\t\"action\": null,\n\t\t\"sp_hostname\": \"your.sharepoint.com\",\n\t\t\"sitepath\": \"\",\n\t\t\"drivename\": \"\",\n\t\t\"spfolderpath\": \"\",\n\t\t\"file_name\": \"\",\n\t\t\"outputfolder\": \"\",\n\t\t\"sp_hostname_1\": \"your.sharepoint.com\",\n\t\t\"sitepath_1\": \"\",\n\t\t\"drivename_1\": \"\",\n\t\t\"spfolderpath_1\": \"\",\n\t\t\"filetoexport\": \"\",\n\t\t\"inputtable1\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"outputtable1\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t}\n\t}\n}","localUi":"{\"pages\":[{\"children\":[{\"id\":\"in_token\",\"label\":\"Personal SharePoint token file\",\"pathtype\":\"file\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/token.json\",\"required\":true,\"type\":\"path\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"SharePoint Token\",\"type\":\"page\"},{\"children\":[{\"id\":\"action\",\"items\":[{\"value\":\"Import\"},{\"value\":\"Export\"}],\"label\":\"Select Action:\",\"placeholder\":\"(no value)\",\"required\":true,\"type\":\"dropdown\",\"visible\":\"\"},{\"children\":[{\"id\":\"sp_hostname\",\"indent\":1,\"label\":\"SharePoint hostname:\",\"placeholder\":\"your.sharepoint.com\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"sitepath\",\"indent\":1,\"label\":\"SharePoint site path:\",\"placeholder\":\"/teams/\\u003cmy SharePoint site name\\u003e\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"drivename\",\"indent\":1,\"label\":\"SharePoint drive name:\",\"placeholder\":\"Documents\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"spfolderpath\",\"indent\":1,\"label\":\"SharePoint folder path:\",\"placeholder\":\"/Users/\\u003cuserid\\u003e\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"file_name\",\"indent\":1,\"label\":\"File Name (add multiple files as: test1.txt, test2.txt; use file extension like .txt or .xlsx to read all files):\",\"placeholder\":\"test.txt\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"outputfolder\",\"label\":\"Output folder:\",\"pathtype\":\"folder\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/files\",\"required\":true,\"type\":\"path\",\"visible\":\"\"}],\"enabled\":[\"$action\",\"=\",\"Import\"],\"id\":\"section1\",\"label\":\"Import Files from SharePoint:\",\"open\":true,\"type\":\"section\",\"visible\":[\"$action\",\"=\",\"Import\"]},{\"children\":[{\"id\":\"sp_hostname_1\",\"indent\":1,\"label\":\"SharePoint hostname\",\"placeholder\":\"your.sharepoint.com\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"sitepath_1\",\"indent\":1,\"label\":\"SharePoint sitepath\",\"placeholder\":\"/teams/\\u003cmy SharePoint site name\\u003e\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"drivename_1\",\"indent\":1,\"label\":\"SharePoint drive name\",\"placeholder\":\"Documents\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"spfolderpath_1\",\"indent\":1,\"label\":\"SharePoint folder path\",\"placeholder\":\"/Users/\\u003cuserid\\u003e\",\"required\":true,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"filetoexport\",\"label\":\"Select file to export\",\"pathtype\":\"file\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/files/test.txt\",\"required\":true,\"type\":\"path\",\"visible\":\"\"}],\"enabled\":[\"$action\",\"=\",\"Export\"],\"id\":\"section2\",\"label\":\"Export Files to SharePoint/OneDrive:\",\"open\":true,\"type\":\"section\",\"visible\":[\"$action\",\"=\",\"Export\"]},{\"children\":[{\"id\":\"inputtable1\",\"label\":\"Input table\",\"placeholder\":\"\",\"required\":false,\"type\":\"inputtable\",\"visible\":\"\"},{\"id\":\"outputtable1\",\"label\":\"Output table\",\"placeholder\":\"\",\"required\":false,\"type\":\"outputtable\",\"visible\":\"\"}],\"id\":\"section3\",\"label\":\"Run this Custom Step\",\"open\":false,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"page2\",\"label\":\"Import/Export files\",\"type\":\"page\"},{\"children\":[{\"id\":\"text1\",\"text\":\"Custome Step to export or import files from/to SharePoint/OneDrive.\\n\\n\\n\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"page3\",\"label\":\"About\",\"type\":\"page\"}],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"action\":null,\"drivename\":\"\",\"drivename_1\":\"\",\"file_name\":\"\",\"filetoexport\":\"\",\"in_token\":\"\",\"inputtable1\":{\"library\":\"\",\"table\":\"\"},\"outputfolder\":\"\",\"outputtable1\":{\"library\":\"\",\"table\":\"\"},\"sitepath\":\"\",\"sitepath_1\":\"\",\"sp_hostname\":\"your.sharepoint.com\",\"sp_hostname_1\":\"your.sharepoint.com\",\"spfolderpath\":\"\",\"spfolderpath_1\":\"\"}}","templates":{"SAS":"/*************************************************************************************************\nAbout This Step: SharePoint Import & Export\n    - by Mayur Jadhav (https://www.linkedin.com/in/mayurjadhavpage/)\n   \nDescription: The core custom step that enables secure file import from SharePoint to SAS Viya \nand export from SAS Viya to SharePoint using the Microsoft Graph API. Supports both Import \nand Export actions through a simple dropdown interface.\n\nSource: The code implemented within these custom steps is derived from, and inspired by,\nthis referenced article:\nhttps://blogs.sas.com/content/sasdummy/2026/02/02/sas-programming-office-365-onedrive/\n\n****************************************************************************************************/\n\n\n*options mlogic mprint symbolgen;\n\n%macro SharePoint;\n\t/* Extract path type (sasserver or sascontent) */\n\t%let token_pathtype=%sysfunc(scan(&in_token., 1, :, M));\n\t%let token_fullpath=%sysfunc(scan(&in_token., 2, :, M));\n\t%let token_filename=%sysfunc(scan(&in_token., -1, /));\n\t%let token_folderpath=%sysfunc(substr(&token_fullpath., 1, \n\t\t%length(&token_fullpath.) - %length(&token_filename.) - 1));\n\t%put NOTE: token Path Type: &token_pathtype.;\n\t%put NOTE: token Full Path: &token_fullpath.;\n\t%put NOTE: token File Path: &token_folderpath.;\n\t%put NOTE: token File Name: &token_filename.;\n\n\t/* Assign the fileref to location that depends on path type */\n\t%macro assignTokenFileref();\n\n\t\t%if %lowcase(&token_pathtype)=sascontent %then %do;\n\n\t\t\t/* Content Path: Use FILESVC with full path */\n\t\t\tfilename token filesrvc\n\t\t\tfolderpath=\"&token_folderpath.\"\n\t\t\tfilename=\"&token_filename.\";\n\t\t\t%put NOTE: Assigning fileref for Content\n\t\t\tPath: &token_folderpath./&token_filename.;\n\t\t%end;\n\t\t%else %do;\n\n\t\t\t/* Server Path: Use standard filename with full path */\n\t\t\tfilename token \"&token_folderpath./&token_filename.\";\n\t\t\t%put NOTE: Assigning fileref for Server\n\t\t\tPath: &token_folderpath./&token_filename.;\n\t\t%end;\n\t%mend assignTokenFileref;\n\n\t%assignTokenFileref;\n\t*filename token \"&token_folderpath./&token_filename.\";\n\t*filename token filesrvc folderpath=\"&token_folderpath.\" filename=\"&token_filename.\";\n\tlibname oauth json fileref=token;\n\n\tdata _null_;\n\t\tset oauth.root;\n\t\tcall symputx('access_token', access_token, 'G');\n\t\tcall symputx('refresh_token', refresh_token, 'G');\n\n\t\t/* convert epoch value to SAS datetime */\n\t\tcall symputx('expires_on', (input(expires_on, best32.)+'01jan1970:00:00'dt), \n\t\t\t'G');\n\trun;\n\n\t%put access_token: &access_token;\n\n\t%if &action=Import %then %do;\n\t\tfilename resp TEMP;\n\n\t\tproc http \n\t\t\t\turl=\"https://graph.microsoft.com/v1.0/sites/&sp_hostname.:&sitepath.:\"\n\n\t\t\t\t/* proc http url=\"https://graph.microsoft.com/v1.0/sites/&hostname.:&sitepath.:/drive\"   ** to get drive id directly  */\n\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\tout=resp;\n\t\trun;\n\n\t\t/* 1. Get Site ID: */\n\t\tlibname jresp json fileref=resp;\n\n\t\t/* store the ID value for the drive in a macro variable */\n\t\tdata _null_;\n\t\t\tset jresp.root;\n\t\t\tsiteid=scan(id, 2, ',');\n\n\t\t\t/* Extracts the second value from the comma-separated string */\n\t\t\tcall symput('siteid', siteid);\n\n\t\t\t/* Assigns the value to a macro variable named 'siteid' */\n\t\trun;\n\n\t\t%put siteid is: &siteid;\n\t\tlibname jresp clear;\n\t\tfilename resp clear;\n\n\t\t/* 2. Get Drive ID: */\n\t\tfilename resp TEMP;\n\n\t\tproc http url=\"https://graph.microsoft.com/v1.0/sites/&siteid./drive\"\n\n\t\t\t/* proc http url=\"https://graph.microsoft.com/v1.0/me/drives/\" */\n\t\t\toauth_bearer=\"&access_token\"\n\t\t\tout=resp;\n\t\trun;\n\n\t\tlibname jresp json fileref=resp;\n\n\t\t/* store the ID value for the drive in a macro variable */\n\t\tproc sql noprint;\n\t\t\tselect id into: driveId from jresp.root where name=\"&drivename.\";\n\t\tquit;\n\n\t\t%put driveId: &driveId;\n\n\t\t/* 3. Get top level folder or files: */\n\t\tfilename resp TEMP;\n\n\t\tproc http \n\t\t\t\turl=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/root/children\"\n\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\tout=resp;\n\t\trun;\n\n\t\tlibname jresp json fileref=resp;\n\n\t\t/* Create a data set with the top-level paths/files in the drive */\n\t\tdata paths;\n\t\t\tset jresp.value;\n\t\trun;\n\n\t\t/*  macro to create macro variables from folder names in a path */\n\t\t%macro create_folder_macros(folder_path);\n\n\t\t\t/* Store original path for full path macro variable */\n\t\t\t%let orig_path=&folder_path.;\n\n\t\t\t/* Use data _null_ to process the folder path */\n\t\t\tdata _null_;\n\t\t\t\tfolder_path=\"&folder_path.\";\n\n\t\t\t\t/* Replace backslashes with forward slashes */\n\t\t\t\tfolder_path=tranwrd(folder_path, '\\', '/');\n\n\t\t\t\t/* Remove trailing slash if present */\n\t\t\t\tif substr(folder_path, length(folder_path), 1)='/' then \n\t\t\t\t\tfolder_path=substr(folder_path, 1, length(folder_path) - 1);\n\n\t\t\t\t/* Remove leading slash if present*/\n\t\t\t\tif substr(folder_path, 1, 1)='/' then new_folder_path=substr(folder_path, \n\t\t\t\t\t2);\n\t\t\t\telse new_folder_path=folder_path;\n\n\t\t\t\t/* Count number of folders (slashes + 1) */\n\t\t\t\tslash_count=countc(new_folder_path, '/') + 1;\n\n\t\t\t\t/* Store processed path and count as macro variables */\n\t\t\t\tcall symputx('new_folder_path', new_folder_path);\n\t\t\t\tcall symputx('slash_count', slash_count);\n\n\t\t\t\t/* Store cleaned full path (without trailing slash) */\n\t\t\t\tcall symputx('clean_full_path', folder_path);\n\t\t\trun;\n\n\t\t\t/* Initialize macro variables */\n\t\t\t%global folder_count folder_full_path;\n\t\t\t%let folder_count=&slash_count.;\n\t\t\t%let folder_full_path=&clean_full_path.;\n\n\t\t\t/* Loop through each folder level */\n\t\t\t%do i=1 %to &slash_count.;\n\n\t\t\t\t/* Extract folder name */\n\t\t\t\t%let folder_name=%scan(&new_folder_path., &i., /);\n\n\t\t\t\t/* Create macro variable for folder name */\n\t\t\t\t%global folder_&i.;\n\t\t\t\t%let folder_&i.=&folder_name.;\n\t\t\t\t%put folder name -- folder_&i. : &folder_name.;\n\t\t\t%end;\n\t\t%mend create_folder_macros;\n\n\t\t/* %let spfolderpath = /BI Users/Mayur Jadhav/files/; */\n\t\t%create_folder_macros(&spfolderpath.);\n\n\t\t/* 4. Get folderitems: */\n\t\t/* Macro to process each folder and overwrite work.paths */\n\t\t%macro process_folders;\n\n\t\t\t/* Loop through each folder based on folder_count */\n\t\t\t%do i=1 %to &folder_count;\n\n\t\t\t\t/* Set foldername to the value of folder_&i */\n\t\t\t\t%let foldername=&&folder_&i;\n\n\t\t\t\t/* Find the ID of the folder */\n\t\t\t\tproc sql noprint;\n\t\t\t\t\tselect id into: folderId from work.paths\n\t\t\t\t\twhere name=\"&foldername.\";\n\t\t\t\tquit;\n\n\t\t\t\t/* Check if folderId was found */\n\t\t\t\t%if &folderId ne %then %do;\n\n\t\t\t\t\t/* store last folder id */\n\t\t\t\t\t%let last_folderID=&folderId;\n\n\t\t\t\t\t/* Call Microsoft Graph API to get folder contents */\n\t\t\t\t\tfilename resp TEMP;\n\n\t\t\t\t\tproc http url=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/&folderId./children\"\n\t\t\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\t\t\tout=resp;\n\t\t\t\t\trun;\n\n\t\t\t\t\t/* Parse JSON response into a dataset */\n\t\t\t\t\tlibname jresp json fileref=resp;\n\n\t\t\t\t\t/* Overwrite work.paths with this folder's contents */\n\t\t\t\t\tdata work.paths;\n\t\t\t\t\t\tset jresp.value;\n\t\t\t\t\t\tfolder_name=\"&foldername\";\n\n\t\t\t\t\t\t/* Add folder name for reference */\n\t\t\t\t\trun;\n\n\t\t\t\t\t/* Clear JSON libname and filename to avoid conflicts */\n\t\t\t\t\tlibname jresp clear;\n\t\t\t\t\tfilename resp clear;\n\t\t\t\t%end;\n\t\t\t\t%else %do;\n\t\t\t\t\t%put WARNING: Folder &foldername not found in work.paths dataset.;\n\t\t\t\t%end;\n\t\t\t%end;\n\t\t%mend process_folders;\n\n\t\t/* Execute the macro */\n\t\t%global last_folderID;\n\t\t%process_folders;\n\t\t%put last FOLDERID : &last_folderID.;\n\n\t\t/* 5. Import files: */\n\t\t/* file names from user input */\n\t\t%let filenames=&file_name.;\n\n\t\t/* Extract path type (sasserver or sascontent) */\n\t\t%let output_pathtype=%sysfunc(scan(&outputfolder., 1, :, M));\n\t\t%let output_folderpath=%sysfunc(scan(&outputfolder., 2, :, M));\n\t\t%put NOTE: output Path Type: &output_pathtype.;\n\t\t%put NOTE: output Folder Path: &output_folderpath.;\n\t\t%put NOTE: output File Names: &filenames.;\n\n\t\t/* Use DATA step to remove spaces and add quotes */\n\t\tdata _null_;\n\t\t\tlength quoted_filenames $200;\n\t\t\tquoted_filenames=\"'\" || tranwrd(compress(upcase(\"&filenames\"), ' '), ',', \n\t\t\t\t\"','\") || \"'\";\n\t\t\tcall symputx('quoted_filenames', quoted_filenames);\n\t\trun;\n\n\t\t/* Display result */\n\t\t%put &quoted_filenames;\n\n\t\t/* Build WHERE clause */\n\t\tdata _null_;\n\t\t\tif find(\"&quoted_filenames\", ',') then call symputx('where_clause', \n\t\t\t\t\"upcase(name) IN (&quoted_filenames)\");\n\t\t\telse call symputx('where_clause', \n\t\t\t\t\"upcase(name) CONTAINS (&quoted_filenames)\");\n\t\trun;\n\n\t\t/* Display result */\n\t\t%put WHERE clause: &where_clause;\n\n\t\t%macro import_file(file_Nm, fileId);\n\t\t\t%put \"file_Nm=&file_Nm.\";\n\t\t\t%put \"file_Id=&fileId.\";\n\n\t\t\t/* Output file */\n\t\t\t/* Assign the fileref to location that depends on path type */\n\t\t\t%if %lowcase(&output_pathtype)=sascontent %then %do;\n\n\t\t\t\t/* Content Path: Use FILESVC with full path */\n\t\t\t\tfilename resp filesrvc\n\t\t\t\tfolderpath=\"&output_folderpath.\"\n\t\t\t\tfilename=\"&file_Nm.\";\n\t\t\t\t%put NOTE: Assigning fileref for Content\n\t\t\t\tPath: &token_folderpath./&token_filename.;\n\t\t\t%end;\n\t\t\t%else %do;\n\n\t\t\t\t/* Server Path: Use standard filename with full path */\n\t\t\t\tfilename resp \"&output_folderpath./&file_Nm.\";\n\t\t\t\t%put NOTE: Assigning fileref for Server\n\t\t\t\tPath: &token_folderpath./&token_filename.;\n\t\t\t%end;\n\t\t\t*filename resp \"&output_folderpath./&file_Nm.\";\n\t\t\t*filename resp filesrvc folderpath=\"&output_folderpath.\" filename=\"&file_Nm.\";\n\n\t\t\tproc http url=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/&fileId./content\"\n\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\tout=resp;\n\t\t\trun;\n\n\t\t\tfilename resp clear;\n\t\t%mend import_file;\n\n\t\tdata _null_;\n\t\t\tset paths;\n\t\t\twhere &where_clause.;\n\t\t\tcall execute('%import_file(' || name || ',' || id ||')');\n\t\trun;\n\n\t\t/* print details */\n\t\t/* Check if output port - outputtable1 macro variable exists */\n\t\t%if %symexist(outputtable1) %then %do;\n\n\t\t\tdata &outputtable1.;\n\t\t\t\tset paths (drop=_microsoft_graph_downloadUrl eTag id cTag);\n\t\t\t\twhere &where_clause.;\n\t\t\trun;\n\n\t\t%end;\n\t\t%else %do;\n\t\t\t%put Note: Output port - outputtable1 is not defined.;\n\t\t%end;\n\t%end;\n\n\t/******** end action=Import section*******/\n\t/****************** start action=Export section***********/\n\t%else %do;\n\n\t\t%if &action=Export %then %do;\n\t\t\tfilename resp TEMP;\n\n\t\t\tproc http \n\t\t\t\t\turl=\"https://graph.microsoft.com/v1.0/sites/&sp_hostname_1.:&sitepath_1.:\"\n\n\t\t\t\t\t/* proc http url=\"https://graph.microsoft.com/v1.0/sites/&hostname.:&sitepath.:/drive\"   ** to get drive id directly  */\n\t\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\t\tout=resp;\n\t\t\trun;\n\n\t\t\t/* 1. Get Site ID: */\n\t\t\tlibname jresp json fileref=resp;\n\n\t\t\t/* store the ID value for the drive in a macro variable */\n\t\t\tdata _null_;\n\t\t\t\tset jresp.root;\n\t\t\t\tsiteid=scan(id, 2, ',');\n\n\t\t\t\t/* Extracts the second value from the comma-separated string */\n\t\t\t\tcall symput('siteid', siteid);\n\n\t\t\t\t/* Assigns the value to a macro variable named 'siteid' */\n\t\t\trun;\n\n\t\t\t%put siteid is: &siteid;\n\t\t\tlibname jresp clear;\n\t\t\tfilename resp clear;\n\n\t\t\t/* 2. Get Drive ID: */\n\t\t\tfilename resp TEMP;\n\n\t\t\tproc http url=\"https://graph.microsoft.com/v1.0/sites/&siteid./drive\"\n\n\t\t\t\t/* proc http url=\"https://graph.microsoft.com/v1.0/me/drives/\" */\n\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\tout=resp;\n\t\t\trun;\n\n\t\t\tlibname jresp json fileref=resp;\n\n\t\t\t/* store the ID value for the drive in a macro variable */\n\t\t\tproc sql noprint;\n\t\t\t\tselect id into: driveId from jresp.root where name=\"&drivename_1.\";\n\t\t\tquit;\n\n\t\t\t%put driveId: &driveId;\n\n\t\t\t/* 3. Get top level folder or files: */\n\t\t\tfilename resp TEMP;\n\n\t\t\tproc http \n\t\t\t\t\turl=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/root/children\"\n\t\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\t\tout=resp;\n\t\t\trun;\n\n\t\t\tlibname jresp json fileref=resp;\n\n\t\t\t/* Create a data set with the top-level paths/files in the drive */\n\t\t\tdata paths;\n\t\t\t\tset jresp.value;\n\t\t\trun;\n\n\t\t\t/*  macro to create macro variables from folder names in a path */\n\t\t\t%macro create_folder_macros(folder_path);\n\n\t\t\t\t/* Store original path for full path macro variable */\n\t\t\t\t%let orig_path=&folder_path.;\n\n\t\t\t\t/* Use data _null_ to process the folder path */\n\t\t\t\tdata _null_;\n\t\t\t\t\tfolder_path=\"&folder_path.\";\n\n\t\t\t\t\t/* Replace backslashes with forward slashes */\n\t\t\t\t\tfolder_path=tranwrd(folder_path, '\\', '/');\n\n\t\t\t\t\t/* Remove trailing slash if present */\n\t\t\t\t\tif substr(folder_path, length(folder_path), 1)='/' then \n\t\t\t\t\t\tfolder_path=substr(folder_path, 1, length(folder_path) - 1);\n\n\t\t\t\t\t/* Remove leading slash if present*/\n\t\t\t\t\tif substr(folder_path, 1, 1)='/' then new_folder_path=substr(folder_path, \n\t\t\t\t\t\t2);\n\t\t\t\t\telse new_folder_path=folder_path;\n\n\t\t\t\t\t/* Count number of folders (slashes + 1) */\n\t\t\t\t\tslash_count=countc(new_folder_path, '/') + 1;\n\n\t\t\t\t\t/* Store processed path and count as macro variables */\n\t\t\t\t\tcall symputx('new_folder_path', new_folder_path);\n\t\t\t\t\tcall symputx('slash_count', slash_count);\n\n\t\t\t\t\t/* Store cleaned full path (without trailing slash) */\n\t\t\t\t\tcall symputx('clean_full_path', folder_path);\n\t\t\t\trun;\n\n\t\t\t\t/* Initialize macro variables */\n\t\t\t\t%global folder_count folder_full_path;\n\t\t\t\t%let folder_count=&slash_count.;\n\t\t\t\t%let folder_full_path=&clean_full_path.;\n\n\t\t\t\t/* Loop through each folder level */\n\t\t\t\t%do i=1 %to &slash_count.;\n\n\t\t\t\t\t/* Extract folder name */\n\t\t\t\t\t%let folder_name=%scan(&new_folder_path., &i., /);\n\n\t\t\t\t\t/* Create macro variable for folder name */\n\t\t\t\t\t%global folder_&i.;\n\t\t\t\t\t%let folder_&i.=&folder_name.;\n\t\t\t\t\t%put folder name -- folder_&i. : &folder_name.;\n\t\t\t\t%end;\n\t\t\t%mend create_folder_macros;\n\n\t\t\t/* %let spfolderpath = /SAS DVH_Users/Mayur Jadhav/files/; */\n\t\t\t%create_folder_macros(&spfolderpath_1.);\n\n\t\t\t/* 4. Get folderitems: */\n\t\t\t/* Macro to process each folder and overwrite work.paths */\n\t\t\t%macro process_folders;\n\n\t\t\t\t/* Loop through each folder based on folder_count */\n\t\t\t\t%do i=1 %to &folder_count;\n\n\t\t\t\t\t/* Set foldername to the value of folder_&i */\n\t\t\t\t\t%let foldername=&&folder_&i;\n\n\t\t\t\t\t/* Find the ID of the folder */\n\t\t\t\t\tproc sql noprint;\n\t\t\t\t\t\tselect id into: folderId from work.paths\n\t\t\t\t\t\twhere name=\"&foldername.\";\n\t\t\t\t\tquit;\n\n\t\t\t\t\t/* Check if folderId was found */\n\t\t\t\t\t%if &folderId ne %then %do;\n\n\t\t\t\t\t\t/* store last folder id */\n\t\t\t\t\t\t%let last_folderID=&folderId;\n\n\t\t\t\t\t\t/* Call Microsoft Graph API to get folder contents */\n\t\t\t\t\t\tfilename resp TEMP;\n\n\t\t\t\t\t\tproc http url=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/&folderId./children\"\n\t\t\t\t\t\t\toauth_bearer=\"&access_token\"\n\t\t\t\t\t\t\tout=resp;\n\t\t\t\t\t\trun;\n\n\t\t\t\t\t\t/* Parse JSON response into a dataset */\n\t\t\t\t\t\tlibname jresp json fileref=resp;\n\n\t\t\t\t\t\t/* Overwrite work.paths with this folder's contents */\n\t\t\t\t\t\tdata work.paths;\n\t\t\t\t\t\t\tset jresp.value;\n\t\t\t\t\t\t\tfolder_name=\"&foldername\";\n\n\t\t\t\t\t\t\t/* Add folder name for reference */\n\t\t\t\t\t\trun;\n\n\t\t\t\t\t\t/* Clear JSON libname and filename to avoid conflicts */\n\t\t\t\t\t\tlibname jresp clear;\n\t\t\t\t\t\tfilename resp clear;\n\t\t\t\t\t%end;\n\t\t\t\t\t%else %do;\n\t\t\t\t\t\t%put WARNING: Folder &foldername not found in work.paths dataset.;\n\t\t\t\t\t%end;\n\t\t\t\t%end;\n\t\t\t%mend process_folders;\n\n\t\t\t/* Execute the macro */\n\t\t\t%global last_folderID;\n\t\t\t%process_folders;\n\t\t\t%put last FOLDERID : &last_folderID.;\n\n\t\t\t/* sharepoint folder where file to be uploaded */\n\t\t\t%let folderId=&last_folderId.;\n\n\t\t\t/* Extract path type (sasserver or sascontent) */\n\t\t\t%let export_pathtype=%sysfunc(scan(&filetoexport., 1, :, M));\n\t\t\t%let export_fullpath=%sysfunc(scan(&filetoexport., 2, :, M));\n\t\t\t%let export_filename=%sysfunc(scan(&filetoexport., -1, /));\n\t\t\t%let export_folderpath=%sysfunc(substr(&export_fullpath., 1, \n\t\t\t\t%length(&export_fullpath.) - %length(&export_filename.) - 1));\n\t\t\t%put NOTE: export Path Type: &export_pathtype.;\n\t\t\t%put NOTE: export Full Path: &export_fullpath.;\n\t\t\t%put NOTE: export File Path: &export_folderpath.;\n\t\t\t%put NOTE: export File Name: &export_filename.;\n\n\t\t\t/* Assign the fileref to location that depends on path type */\n\t\t\t%macro assignExportFileref();\n\n\t\t\t\t%if %lowcase(&export_pathtype)=sascontent %then %do;\n\n\t\t\t\t\t/* Content Path: Use FILESVC with full path */\n\t\t\t\t\tfilename tosave filesrvc\n\t\t\t\t\tfolderpath=\"&export_folderpath.\"\n\t\t\t\t\tfilename=\"&export_filename.\";\n\t\t\t\t\t%put NOTE: Assigning fileref for Content\n\t\t\t\t\tPath: &export_folderpath./&export_filename.;\n\t\t\t\t%end;\n\t\t\t\t%else %do;\n\n\t\t\t\t\t/* Server Path: Use standard filename with full path */\n\t\t\t\t\tfilename tosave \"&export_folderpath./&export_filename.\";\n\t\t\t\t\t%put NOTE: Assigning fileref for Server\n\t\t\t\t\tPath: &export_folderpath./&export_filename.;\n\t\t\t\t%end;\n\t\t\t%mend assignExportFileref;\n\n\t\t\t%assignExportFileref;\n\t\t\t*filename tosave \"&export_folderpath./&export_filename.\";\n\t\t\t*filename tosave filesrvc folderpath=\"&export_folderpath.\" filename=\"&export_filename.\";\n\t\t\tfilename details temp;\n\n\t\t\tproc http url=\"https://graph.microsoft.com/v1.0/me/drives/&driveId./items/&folderId.:/&export_filename.:/content\"\n\t\t\t\tmethod=\"PUT\"\n\t\t\t\tin=tosave\n\t\t\t\tout=details\n\t\t\t\toauth_bearer=\"&access_token\";\n\t\t\trun;\n\n\t\t\t/*\n\t\t\tThis returns a json response that describes the item uploaded.\n\t\t\tThis step pulls out the main file attributes from that response.\n\t\t\t*/\n\t\t\tlibname attrs json fileref=details;\n\n\t\t\t/* print details */\n\t\t\t/* Check if output port - outputtable1 macro variable exists */\n\t\t\t%if %symexist(outputtable1) %then %do;\n\n\t\t\t\tdata &outputtable1. (keep=filename createdDate modifiedDate filesize);\n\t\t\t\t\tlength filename $ 100 createdDate 8 modifiedDate 8 filesize 8;\n\t\t\t\t\tset attrs.root;\n\t\t\t\t\tfilename=name;\n\t\t\t\t\tmodifiedDate=input(lastModifiedDateTime, anydtdtm.);\n\t\t\t\t\tcreatedDate=input(createdDateTime, anydtdtm.);\n\t\t\t\t\tformat createdDate datetime20. modifiedDate datetime20.;\n\t\t\t\t\tfilesize=size;\n\t\t\t\trun;\n\n\t\t\t%end;\n\t\t\t%else %do;\n\t\t\t\t%put Note: Output port - outputtable1 is not defined.;\n\t\t\t%end;\n\t\t%end;\n\t%end;\n\n\t/**************** end action=Export section********/\n%mend SharePoint;\n\n/* execute this entire custome step code */\n%SharePoint;"}}
