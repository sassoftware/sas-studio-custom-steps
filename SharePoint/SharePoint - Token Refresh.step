{"creationTimeStamp":"2026-06-02T22:03:12.908227Z","createdBy":"Mayur.Jadhav@posten.no","modifiedTimeStamp":"2026-06-02T22:10:59.294477Z","modifiedBy":"Mayur.Jadhav@posten.no","id":"1f6b34e2-9e16-4f06-aacf-48db6500c30e","name":"0601SharePoint - Token Refresh.step","displayName":"0601SharePoint - Token Refresh.step","localDisplayName":"0601SharePoint - Token Refresh.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e/copy","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","uri":"/dataFlows/steps/1f6b34e2-9e16-4f06-aacf-48db6500c30e","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"outputPorts":[{"name":"outputtable1","displayName":"outputtable1","localDisplayName":"outputtable1","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"SharePoint Auth\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Refresh token\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sp_config\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint config file (e.g. config.json)\",\n\t\t\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/config.json\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"personal_token\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint personal token file (e.g. token.json)\",\n\t\t\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/token.json\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section2\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Output port\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"outputtable1\",\n\t\t\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\t\t\"label\": \"Output table\",\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page3\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"Custome Step to refresh SharePoint/OneDrive personal token. Your Personal auth token will be refreshed and stored in specified .json file.\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"sp_config\": \"\",\n\t\t\"personal_token\": \"\",\n\t\t\"outputtable1\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t}\n\t}\n}","localUi":"{\"pages\":[{\"children\":[{\"children\":[{\"id\":\"sp_config\",\"label\":\"SharePoint config file (e.g. config.json)\",\"pathtype\":\"file\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/config.json\",\"required\":true,\"type\":\"path\",\"visible\":\"\"},{\"id\":\"personal_token\",\"label\":\"SharePoint personal token file (e.g. token.json)\",\"pathtype\":\"file\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/token.json\",\"required\":true,\"type\":\"path\",\"visible\":\"\"}],\"id\":\"section1\",\"label\":\"Refresh token\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"outputtable1\",\"label\":\"Output table\",\"placeholder\":\"\",\"required\":false,\"type\":\"outputtable\",\"visible\":\"\"}],\"id\":\"section2\",\"label\":\"Output port\",\"open\":false,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"SharePoint Auth\",\"type\":\"page\"},{\"children\":[{\"id\":\"text1\",\"text\":\"Custome Step to refresh SharePoint/OneDrive personal token. Your Personal auth token will be refreshed and stored in specified .json file.\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"page3\",\"label\":\"About\",\"type\":\"page\"}],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"outputtable1\":{\"library\":\"\",\"table\":\"\"},\"personal_token\":\"\",\"sp_config\":\"\"}}","templates":{"SAS":"/*************************************************************************************************\nAbout This Step: Refresh Access Token\n    - by Mayur Jadhav (https://www.linkedin.com/in/mayurjadhavpage/)\n    \nDescription: This step renews an expiring OAuth 2.0 access token using a valid refresh token. \nIt ensures uninterrupted access to SharePoint during long-running jobs or scheduled flows.\n\nSource: The code implemented within these custom steps is derived from, and inspired by, \nthis referenced article:\nhttps://blogs.sas.com/content/sasdummy/2026/02/02/sas-programming-office-365-onedrive/\n\n****************************************************************************************************/\n\n/* Extract path type (sasserver or sascontent) */\n%let config_pathtype=%sysfunc(scan(&sp_config., 1, :, M));\n%let config_fullpath=%sysfunc(scan(&sp_config., 2, :, M));\n%let config_filename=%sysfunc(scan(&sp_config., -1, /));\n%let config_folderpath=%sysfunc(substr(&config_fullpath., 1, \n\t%length(&config_fullpath.) - %length(&config_filename.) - 1));\n%put NOTE: Config Path Type: &config_pathtype.;\n%put NOTE: Config File Path: &config_folderpath.;\n%put NOTE: Config File Name: &config_filename.;\n\n/* Assign the fileref to location that depends on path type */\n%macro assignConfigFileref;\n\t%if %lowcase(&config_pathtype)=sascontent %then %do;\n\n\t\t/* Content Path: Use FILESVC with full path */\n\t\tfilename config filesrvc\n\t\tfolderpath=\"&config_folderpath.\"\n\t\tfilename=\"&config_filename.\";\n\t\t%put NOTE: Assigning fileref for Content \n\t\t\tPath: &config_folderpath./&config_filename.;\n\t%end;\n\t%else %do;\n\n\t\t/* Server Path: Use standard filename with full path */\n\t\tfilename config \"&config_folderpath./&config_filename.\";\n\t\t%put NOTE: Assigning fileref for Server \n\t\t\tPath: &config_folderpath./&config_filename.;\n\t%end;\n%mend assignConfigFileref;\n\n%assignConfigFileref;\n*filename config \"&config_folderpath./&config_filename.\";\n*filename config filesrvc folderpath=\"&config_folderpath.\" filename=\"&config_filename.\";\nlibname jconfig json fileref=config;\n\ndata _null_;\n\tset jconfig.root;\n\tcall symputx('tenant_id', tenant_id, 'G');\n\tcall symputx('client_id', client_id, 'G');\n\tcall symputx('redirect_uri', redirect_uri, 'G');\n\tcall symputx('resource', resource, 'G');\nrun;\n\n%macro process_token_file(file);\n\tlibname oauth json fileref=&file.;\n\n\tdata _null_;\n\t\tset oauth.root;\n\t\tcall symputx('access_token', access_token, 'G');\n\t\tcall symputx('refresh_token', refresh_token, 'G');\n\n\t\t/* convert epoch value to SAS datetime */\n\t\tcall symputx('expires_on', (input(expires_on, best32.)+'01jan1970:00:00'dt), \n\t\t\t'G');\n\trun;\n\n%mend;\n\n%macro refresh(client_id, refresh_token, resource, outfile, \n\t\tredirect_uri=https://login.microsoftonline.com/common/oauth2/nativeclient, \n\t\ttenant=common, debug=0);\n\tproc http url=\"https://login.microsoft.com/&tenant_id./oauth2/token\"\n\t\tmethod=\"POST\"\n\t\tin=\"%nrstr(&client_id)=&client_id.%nrstr(&refresh_token=)&refresh_token%nrstr(&redirect_uri)=&redirect_uri.%nrstr(&grant_type)=refresh_token%nrstr(&resource)=&resource.\"\n\t\tout=&outfile.;\n\t\t%if &debug. ge 0 %then %do;\n\t\t\tdebug level=&debug.;\n\t\t%end;\n\t\t%else %if %symexist(_DEBUG_) AND &_DEBUG_. ge 1 %then %do;\n\t\t\tdebug level=&_DEBUG_.;\n\t\t%end;\n\trun;\n\n\t%process_token_file(&outfile);\n%mend refresh;\n\n/* Extract path type (sasserver or sascontent) */\n%let token_pathtype=%sysfunc(scan(&personal_token., 1, :, M));\n%let token_fullpath=%sysfunc(scan(&personal_token., 2, :, M));\n%let token_filename=%sysfunc(scan(&personal_token., -1, /));\n%let token_folderpath=%sysfunc(substr(&token_fullpath., 1, \n\t%length(&token_fullpath.) - %length(&token_filename.) - 1));\n%put NOTE: token Path Type: &token_pathtype.;\n%put NOTE: token Full Path: &token_fullpath.;\n%put NOTE: token File Path: &token_folderpath.;\n%put NOTE: token File Name: &token_filename.;\n\n/* Assign the fileref to location that depends on path type */\n%macro assignTokenFileref();\n\t%if %lowcase(&token_pathtype)=sascontent %then %do;\n\n\t\t/* Content Path: Use FILESVC with full path */\n\t\tfilename token filesrvc\n\t\tfolderpath=\"&token_folderpath.\"\n\t\tfilename=\"&token_filename.\";\n\t\t%put NOTE: Assigning fileref for Content \n\t\t\tPath: &token_folderpath./&token_filename.;\n\t%end;\n\t%else %do;\n\n\t\t/* Server Path: Use standard filename with full path */\n\t\tfilename token \"&token_folderpath./&token_filename.\";\n\t\t%put NOTE: Assigning fileref for Server \n\t\t\tPath: &token_folderpath./&token_filename.;\n\t%end;\n%mend assignTokenFileref;\n\n%assignTokenFileref;\n*filename token \"&token_folderpath./&token_filename.\";\n*filename token filesrvc folderpath=\"&token_folderpath.\" filename=\"&token_filename.\";\n%process_token_file(token);\n%refresh(&client_id., &refresh_token., &resource., token, tenant=&tenant_id.);\n\n/* Check if output port - outputtable1 macro variable exists */\n%if %symexist(outputtable1) %then %do;\n\n\tdata &outputtable1.;\n\t\tset oauth.root;\n\trun;\n\n%end;\n%else %do;\n\t%put Note: Output port - outputtable1 is not defined.;\n%end;"}}
