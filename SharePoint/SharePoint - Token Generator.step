{"creationTimeStamp":"2026-06-02T22:03:12.7758Z","createdBy":"Mayur.Jadhav@posten.no","modifiedTimeStamp":"2026-06-02T22:17:22.427258Z","modifiedBy":"Mayur.Jadhav@posten.no","id":"c9cc9761-69ea-4795-bae8-a0122e90c9ca","name":"0601SharePoint - Token Generator.step","displayName":"0601SharePoint - Token Generator.step","localDisplayName":"0601SharePoint - Token Generator.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca/copy","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","uri":"/dataFlows/steps/c9cc9761-69ea-4795-bae8-a0122e90c9ca","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"outputPorts":[{"name":"outputtable1","displayName":"outputtable1","localDisplayName":"outputtable1","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"OneDrive Auth\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Authentication Code\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"sp_config\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint config file (e.g. config.json)\",\n\t\t\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>/config.json\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"text2\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"This step will provide you with a personal authentication code for Microsoft Entra ID, which you can use to connect to SharePoint from SAS Viya. \\n\\nTo get your personal SharePoint authentication code:\\n\\n1. Build the authorization URL: \\n\\nPut 1): tenant_id, 2): client_id, 3): redirect_uri, and 4): resource, from the previously selected config file into this URL format, i.e. replace four &values below to generate URL: \\n\\nauthorize_url=https://login.microsoftonline.com/&tenant_id./oauth2/authorize?client_id=&client_id&response_type=code&redirect_uri=&redirect_uri&resource=&resource\\n\\nAuthorization URL Example (with current four parameters per 2025). Compare and validate with the instructions above:\\n\\nhttps://login.microsoftonline.com/<tenant_id>/oauth2/authorize?client_id=<client_id>&response_type=code&redirect_uri=https://login.microsoftonline.com/common/oauth2/nativeclient&resource=https://graph.microsoft.com\\n\\n2. Copy and paste above prepared auth URL into the web browser:\\n\\nWhen you press Enter, you'll be prompted to select appropriate user for sign in. The browser will redirect to what looks like a blank page, but the new resulting URL contains the authorization code that we need.\\n\\n3. Copy the value that appears after the code= in the new URL.\\n\\nCopy text only up to the &session= part and paste it in the below auth_code text box. NB! This is long URL , typical > 700 characters. Paste it in Notepad, and identify code= (at start) and &session= (at the end). Then copy all text in between (> 700 characters): \\n\\nFor example:\\n***code=<copy this code>&session=***\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"auth_code\",\n\t\t\t\t\t\t\t\"type\": \"textarea\",\n\t\t\t\t\t\t\t\"label\": \"auth_code\",\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section2\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"SharePoint token file will be generated and stored in the token file folder\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"tokenfilename\",\n\t\t\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\t\t\"label\": \"SharePoint personal token file name (e.g. token.json):\",\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"in_tokenfilefolder\",\n\t\t\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\t\t\"label\": \"NB! Save your personal token file in your personal folder (My Folder, etc): \",\n\t\t\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\t\t\"placeholder\": \"/pb/Users/<userid>\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section3\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"4. Run this Custom Step.  \",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"outputtable1\",\n\t\t\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\t\t\"label\": \"Output table\",\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page3\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"Custome Step to generate OneDrive personal token. Your Personal auth token will be generated and stored in token.json file under /pb/Users/&userid./\\n\\n\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"sp_config\": \"\",\n\t\t\"auth_code\": \"\",\n\t\t\"tokenfilename\": \"\",\n\t\t\"in_tokenfilefolder\": \"\",\n\t\t\"outputtable1\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t}\n\t}\n}","localUi":"{\"pages\":[{\"children\":[{\"children\":[{\"id\":\"sp_config\",\"label\":\"SharePoint config file (e.g. config.json)\",\"pathtype\":\"file\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e/config.json\",\"required\":true,\"type\":\"path\",\"visible\":\"\"},{\"id\":\"text2\",\"text\":\"This step will provide you with a personal authentication code for Microsoft Entra ID, which you can use to connect to SharePoint from SAS Viya. \\n\\nTo get your personal SharePoint authentication code:\\n\\n1. Build the authorization URL: \\n\\nPut 1): tenant_id, 2): client_id, 3): redirect_uri, and 4): resource, from the previously selected config file into this URL format, i.e. replace four \\u0026values below to generate URL: \\n\\nauthorize_url=https://login.microsoftonline.com/\\u0026tenant_id./oauth2/authorize?client_id=\\u0026client_id\\u0026response_type=code\\u0026redirect_uri=\\u0026redirect_uri\\u0026resource=\\u0026resource\\n\\nAuthorization URL Example (with current four parameters per 2025). Compare and validate with the instructions above:\\n\\nhttps://login.microsoftonline.com/\\u003ctenant_id\\u003e/oauth2/authorize?client_id=\\u003cclient_id\\u003e\\u0026response_type=code\\u0026redirect_uri=https://login.microsoftonline.com/common/oauth2/nativeclient\\u0026resource=https://graph.microsoft.com\\n\\n2. Copy and paste above prepared auth URL into the web browser:\\n\\nWhen you press Enter, you'll be prompted to select appropriate user for sign in. The browser will redirect to what looks like a blank page, but the new resulting URL contains the authorization code that we need.\\n\\n3. Copy the value that appears after the code= in the new URL.\\n\\nCopy text only up to the \\u0026session= part and paste it in the below auth_code text box. NB! This is long URL , typical \\u003e 700 characters. Paste it in Notepad, and identify code= (at start) and \\u0026session= (at the end). Then copy all text in between (\\u003e 700 characters): \\n\\nFor example:\\n***code=\\u003ccopy this code\\u003e\\u0026session=***\",\"type\":\"text\",\"visible\":\"\"},{\"id\":\"auth_code\",\"label\":\"auth_code\",\"placeholder\":\"\",\"required\":true,\"type\":\"textarea\",\"visible\":\"\"}],\"id\":\"section1\",\"label\":\"Authentication Code\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"tokenfilename\",\"label\":\"SharePoint personal token file name (e.g. token.json):\",\"placeholder\":\"\",\"required\":false,\"type\":\"textfield\",\"visible\":\"\"},{\"id\":\"in_tokenfilefolder\",\"label\":\"NB! Save your personal token file in your personal folder (My Folder, etc): \",\"pathtype\":\"folder\",\"placeholder\":\"/pb/Users/\\u003cuserid\\u003e\",\"required\":true,\"type\":\"path\",\"visible\":\"\"}],\"id\":\"section2\",\"label\":\"SharePoint token file will be generated and stored in the token file folder\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"outputtable1\",\"label\":\"Output table\",\"placeholder\":\"\",\"required\":false,\"type\":\"outputtable\",\"visible\":\"\"}],\"id\":\"section3\",\"label\":\"4. Run this Custom Step.  \",\"open\":false,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"OneDrive Auth\",\"type\":\"page\"},{\"children\":[{\"id\":\"text1\",\"text\":\"Custome Step to generate OneDrive personal token. Your Personal auth token will be generated and stored in token.json file under /pb/Users/\\u0026userid./\\n\\n\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"page3\",\"label\":\"About\",\"type\":\"page\"}],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"auth_code\":\"\",\"in_tokenfilefolder\":\"\",\"outputtable1\":{\"library\":\"\",\"table\":\"\"},\"sp_config\":\"\",\"tokenfilename\":\"\"}}","templates":{"SAS":"/*************************************************************************************************\nAbout This Step: Generate Access Token\n    - by Mayur Jadhav (https://www.linkedin.com/in/mayurjadhavpage/)\n   \nDescription: This custom step submits a POST request to the Microsoft identity platform \nto obtain an OAuth 2.0 access token. The token file is stored into specified file location for use in subsequent steps.\n\nSource: The code implemented within these custom steps is derived from, and inspired by,\nthis referenced article:\nhttps://blogs.sas.com/content/sasdummy/2026/02/02/sas-programming-office-365-onedrive/\n\n****************************************************************************************************/\n\n/* Extract path type (sasserver or sascontent) */\n%let config_pathtype=%sysfunc(scan(&sp_config., 1, :, M));\n%let config_fullpath=%sysfunc(scan(&sp_config., 2, :, M));\n%let config_filename=%sysfunc(scan(&sp_config., -1, /));\n%let config_folderpath=%sysfunc(substr(&config_fullpath., 1, \n\t%length(&config_fullpath.) - %length(&config_filename.) - 1));\n%put NOTE: Config Path Type: &config_pathtype.;\n%put NOTE: Config File Path: &config_folderpath.;\n%put NOTE: Config File Name: &config_filename.;\n\n/* Assign the fileref to location that depends on path type */\n%macro assignConfigFileref;\n\t%if %lowcase(&config_pathtype)=sascontent %then %do;\n\n\t\t/* Content Path: Use FILESVC with full path */\n\t\tfilename config filesrvc\n\t\tfolderpath=\"&config_folderpath.\"\n\t\tfilename=\"&config_filename.\";\n\t\t%put NOTE: Assigning fileref for Content \n\t\t\tPath: &config_folderpath./&config_filename.;\n\t%end;\n\t%else %do;\n\n\t\t/* Server Path: Use standard filename with full path */\n\t\tfilename config \"&config_folderpath./&config_filename.\";\n\t\t%put NOTE: Assigning fileref for Server \n\t\t\tPath: &config_folderpath./&config_filename.;\n\t%end;\n%mend assignConfigFileref;\n\n%assignConfigFileref;\n*filename config \"&config_folderpath./&config_filename.\";\n*filename config filesrvc folderpath=\"&config_folderpath.\" filename=\"&config_filename.\";\nlibname jconfig json fileref=config;\n\ndata _null_;\n\tset jconfig.root;\n\tcall symputx('tenant_id', tenant_id, 'G');\n\tcall symputx('client_id', client_id, 'G');\n\tcall symputx('redirect_uri', redirect_uri, 'G');\n\tcall symputx('resource', resource, 'G');\nrun;\n\n%macro process_token_file(file);\n\tlibname oauth json fileref=&file.;\n\n\tdata _null_;\n\t\tset oauth.root;\n\t\tcall symputx('access_token', access_token, 'G');\n\t\tcall symputx('refresh_token', refresh_token, 'G');\n\n\t\t/* convert epoch value to SAS datetime */\n\t\tcall symputx('expires_on', (input(expires_on, best32.)+'01jan1970:00:00'dt), \n\t\t\t'G');\n\trun;\n\n%mend;\n\n/*\nUtility macro that retrieves the initial access token\nby redeeming the authorization code that you're granted\nduring the interactive step using a web browser\nwhile signed into your Microsoft OneDrive / Azure account.\n\nThis step also creates the initial token.json that will be\nused later to redeem a refresh token.\n*/\n%macro get_token(client_id, code, resource, outfile, \n\t\tredirect_uri=https://login.microsoftonline.com/common/oauth2/nativeclient, \n\t\ttenant=common, debug=0);\n\tproc http url=\"https://login.microsoft.com/&tenant_id./oauth2/token\"\n\t\tmethod=\"POST\"\n\t\tin=\"%nrstr(&client_id)=&client_id.%nrstr(&code)=&code.%nrstr(&redirect_uri)=&redirect_uri%nrstr(&grant_type)=authorization_code%nrstr(&resource)=&resource.\"\n\t\tout=&outfile.;\n\t\t%if &debug>=0 %then %do;\n\t\t\tdebug level=&debug.;\n\t\t%end;\n\t\t%else %if &_DEBUG_. ge 1 %then %do;\n\t\t\tdebug level=&_DEBUG_.;\n\t\t%end;\n\trun;\n\n\t%process_token_file(&outfile);\n%mend;\n\n%put in_tokenfilefolder: &in_tokenfilefolder.;\n\n/* Extract path type (sasserver or sascontent) */\n%let token_pathtype=%sysfunc(scan(&in_tokenfilefolder., 1, :, M));\n%let token_folderpath=%sysfunc(scan(&in_tokenfilefolder., 2, :, M));\n\n/* Assign the fileref to location that depends on path type */\n%macro assignTokenFileref();\n\t%if %lowcase(&token_pathtype)=sascontent %then %do;\n\n\t\t/* Content Path: Use FILESVC with full path */\n\t\tfilename token filesrvc\n\t\tfolderpath=\"&token_folderpath.\"\n\t\tfilename=\"&tokenfilename.\";\n\t\t%put NOTE: Assigning fileref for Content \n\t\t\tPath: &token_folderpath./&tokenfilename.;\n\t%end;\n\t%else %do;\n\n\t\t/* Server Path: Use standard filename with full path */\n\t\tfilename token \"&token_folderpath./&tokenfilename.\";\n\t\t%put NOTE: Assigning fileref for Server \n\t\t\tPath: &token_folderpath./&tokenfilename.;\n\t%end;\n%mend assignTokenFileref;\n\n%assignTokenFileref;\n*filename token \"&token_folderpath./&tokenfilename.\";\n*filename token filesrvc folderpath=\"&token_folderpath.\" filename=\"&tokenfilename.\";\n%get_token(&client_id., &auth_code, &resource., token, tenant=&tenant_id);\n\n/* print details */\n/* Check if output port - outputtable1 macro variable exists */\n%if %symexist(outputtable1) %then %do;\n\n\tdata &outputtable1.;\n\t\tset oauth.root;\n\trun;\n\n%end;\n%else %do;\n\t%put Note: Output port - outputtable1 is not defined.;\n%end;"}}
