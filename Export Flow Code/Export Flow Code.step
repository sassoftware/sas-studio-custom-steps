{"creationTimeStamp":"2026-02-16T14:13:08.098369Z","createdBy":"Remco.Gooijer@sas.com","modifiedTimeStamp":"2026-03-03T13:13:20.593646Z","modifiedBy":"Remco.Gooijer@sas.com","id":"e78143d0-f61b-45f4-86f2-c46b6258d004","name":"Export Flow Code.step","displayName":"Export Flow Code.step","localDisplayName":"Export Flow Code.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004/copy","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","uri":"/dataFlows/steps/e78143d0-f61b-45f4-86f2-c46b6258d004","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Options\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_flowFolder\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select the folder that contains the flows:\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_codeFolder\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select the directory where the .sas files will be stored:\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_maxFlows\",\n\t\t\t\t\t\"type\": \"numberfield\",\n\t\t\t\t\t\"label\": \"Specify the maximum number of flows to process:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": 10,\n\t\t\t\t\t\"excludemin\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"integer\": true\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_httpTimeOut\",\n\t\t\t\t\t\"type\": \"numberfield\",\n\t\t\t\t\t\"label\": \"HTTP time-out, in seconds:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": 60,\n\t\t\t\t\t\"excludemin\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"integer\": true\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Code generation options:\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"_userAutoExec\",\n\t\t\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\t\t\"label\": \"User autoexec\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"_wrapperCode\",\n\t\t\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\t\t\"label\": \"Wrapper code\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"_initCode\",\n\t\t\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\t\t\"label\": \"Init code\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"\\nExport Flow Code\\n===============\\n\\nThis custom step is able to export one or more SAS Studio Flow(s) stored in a, content- or physical, directory to one or more .sas files, stored on a physical location.\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"section2\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Changelog\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"text2\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"* Version 1.0\\n    - Initial version\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_flowFolder\": \"\",\n\t\t\"_codeFolder\": \"\",\n\t\t\"_maxFlows\": 250,\n\t\t\"_httpTimeOut\": 120,\n\t\t\"_userAutoExec\": false,\n\t\t\"_wrapperCode\": false,\n\t\t\"_initCode\": false\n\t},\n\t\"promptHierarchies\": []\n}","localUi":"{\"pages\":[{\"children\":[{\"id\":\"_flowFolder\",\"label\":\"Select the folder that contains the flows:\",\"pathtype\":\"folder\",\"placeholder\":\"\",\"required\":true,\"type\":\"path\",\"visible\":\"\"},{\"id\":\"_codeFolder\",\"label\":\"Select the directory where the .sas files will be stored:\",\"pathtype\":\"folder\",\"placeholder\":\"\",\"required\":true,\"type\":\"path\",\"visible\":\"\"},{\"excludemin\":false,\"id\":\"_maxFlows\",\"integer\":true,\"label\":\"Specify the maximum number of flows to process:\",\"max\":null,\"min\":10,\"placeholder\":\"\",\"required\":true,\"type\":\"numberfield\",\"visible\":\"\"},{\"excludemin\":false,\"id\":\"_httpTimeOut\",\"integer\":true,\"label\":\"HTTP time-out, in seconds:\",\"max\":null,\"min\":60,\"placeholder\":\"\",\"required\":true,\"type\":\"numberfield\",\"visible\":\"\"},{\"children\":[{\"id\":\"_userAutoExec\",\"label\":\"User autoexec\",\"type\":\"checkbox\",\"visible\":\"\"},{\"id\":\"_wrapperCode\",\"label\":\"Wrapper code\",\"type\":\"checkbox\",\"visible\":\"\"},{\"id\":\"_initCode\",\"label\":\"Init code\",\"type\":\"checkbox\",\"visible\":\"\"}],\"id\":\"section1\",\"label\":\"Code generation options:\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"Options\",\"type\":\"page\"},{\"children\":[{\"id\":\"text1\",\"text\":\"\\nExport Flow Code\\n===============\\n\\nThis custom step is able to export one or more SAS Studio Flow(s) stored in a, content- or physical, directory to one or more .sas files, stored on a physical location.\",\"type\":\"text\",\"visible\":\"\"},{\"children\":[{\"id\":\"text2\",\"text\":\"* Version 1.0\\n    - Initial version\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"section2\",\"label\":\"Changelog\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"page2\",\"label\":\"About\",\"type\":\"page\"}],\"promptHierarchies\":[],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"_codeFolder\":\"\",\"_flowFolder\":\"\",\"_httpTimeOut\":120,\"_initCode\":false,\"_maxFlows\":250,\"_userAutoExec\":false,\"_wrapperCode\":false}}","templates":{"SAS":"data _null_; \r\n\tcall symputx('viyaHost', kreverse(ksubstr(ksubstr(kreverse(\"&_BASEURL.\"), 2), kfind(ksubstr(kreverse(\"&_BASEURL.\"), 2), '/') + 1)));\r\n    call symputx(\"flowPath\", kscan(\"&_flowFolder\", 2, ':'));\r\n    call symputx(\"codePath\", kscan(\"&_codeFolder\", 2, ':'));\r\n    \r\n    /*\r\n        The custom step supports only physical directories to write the resulting code files to.\r\n    */\r\n    call symputx(\"codePathType\", kscan(\"&_codeFolder\", 1, ':'));\r\n   \r\n    /*\r\n        The JSON request only accepts true of false, not 1 or 0.\r\n    */\r\n    call symputx(\"userAutoExec\", ifc(&_userAutoExec, 'true', 'false'));\r\n    call symputx(\"wrapperCode\", ifc(&_wrapperCode, 'true', 'false'));\r\n    call symputx(\"initCode\", ifc(&_initCode, 'true', 'false'));\r\n\r\n    /*\r\n        Determine the content type, 'content' or 'compute'.\r\n    */\r\n    call symputx(\"flowPathType\", ifc(upcase(kscan(\"&_flowFolder\", 1, ':')) = \"SASCONTENT\", \"content\", \"compute\"));\r\nrun;\r\n\r\n/*\r\n    The 'flows' macro variable will contain the names of the flows\r\n    to export, separated with an |, independed from the contentType (= content or compute).\r\n    nbrFlows will contain the number of flows to be processed.\r\n*/\r\n%let flows=;\r\n%let nbrFlows=0;\r\n%macro directoryContent(\r\n    contentType=\r\n);\r\n    %put NOTE: == Input parameters for macro: directoryContent ==;\r\n    %put NOTE: &=contentType;\r\n    %put NOTE: == Input end ==;\r\n    \r\n    /*\r\n        The macro variable contentType is used to indicate where the flow(s) is/are located:\r\n        - content: The flow is located in SAS content\r\n        - compute: The flow is located on a physical location.\r\n    */\r\n    %if &contentType eq content %then %do;\r\n        /*\r\n            The flows are located in SAS content.\r\n            \r\n            Get the directory URI to retrieve the members within the specified content directory.\r\n        */\r\n        filename ref temp;\r\n        proc http\r\n            url = \"&viyaHost./folders/folders/@item\"\r\n                query = (\"path\" = \"&flowPath\")\r\n            oauth_bearer = sas_services\r\n            out= ref;\r\n            headers\r\n                'Accept'= 'application/vnd.sas.content.folder+json';\r\n        run;\r\n        %if %sysfunc(fexist(ref)) %then %do;\r\n            libname ref json;\r\n            /*\r\n                From the links table, store the end-point and the content type into macro variables.\r\n            */\r\n            proc sql noprint;\r\n                select \r\n                    href, \r\n                    type into :endpoint, :type\r\n                from \r\n                    ref.links\r\n                where \r\n                    upcase(method) = \"GET\" and \r\n                    upcase(rel) = \"MEMBERS\";\r\n            quit;\r\n            /*\r\n                Removing unnecessary objects.\r\n            */\r\n            libname ref clear;\r\n            filename ref clear;\r\n\r\n            /*\r\n                Retrieve the flows from the specified contents directory.\r\n            */\r\n            filename members temp; \r\n            proc http\r\n                url = \"&viyaHost.%trim(&endpoint)?limit=&_maxFlows\"\r\n                oauth_bearer = sas_services\r\n                out = members;\r\n                headers\r\n                    \"Accept\"= \"%trim(&type)+json\";\r\n            run; \r\n            %if %sysfunc(fexist(members)) %then %do;    \r\n                /*\r\n                    Put all the flow names into the 'flows' macro variable.\r\n                */\r\n                libname members json;\r\n                proc sql noprint;\r\n                    select \r\n                        strip(name) into :flows separated by '|'\r\n                    from\r\n                        members.items\r\n                    where\r\n                        /*\r\n                            The contents can also contain non-flow objects.\r\n                        */\r\n                        upcase(contentType) = \"DATAFLOW\";\r\n                quit;\r\n\r\n                /*\r\n                    Removing unnecessary objects.\r\n                */\r\n                libname members clear;\r\n                filename members clear;\r\n            %end;\r\n            %else %do;\r\n                %put ERROR: Unable to retrieve content directory members.;\r\n            %end;\r\n        %end;\r\n        %else %do;\r\n            %put ERROR: Unable to retrieve content directory.;\r\n        %end;\r\n    %end;\r\n    %else %do;\r\n        /*\r\n            The directory containing flows is located on a physical directory.\r\n        */\r\n        %let regexp =%sysfunc(tranwrd(*.flw ,.,\\.));\r\n\t    %let regexp2=%sysfunc(tranwrd(&regexp,*,.*));\r\n\t    %let regexp3=%sysfunc(tranwrd(&regexp2,?,.));\r\n\t    %let pattern =/&regexp3/;         \r\n         \r\n\t    data items(keep=filename);          \r\n\t\t    length      \r\n\t\t\t    fref $8\r\n                directory $256\r\n\t    \t\tfilename $256;         \r\n     \r\n\t\t    if ksubstr(kreverse(\"&flowPath\"), 1, 1) ^= '/' then do;         \r\n\t\t\t    directory = strip(\"&flowPath\" || '/');\t         \r\n\t\t    end;         \r\n\t\t    else do;         \r\n\t\t\t    directory = strip(\"&flowPath\");         \r\n\t\t    end;         \r\n         \r\n\t\t    rc = filename(fref, \"'&flowPath'\");          \r\n\t\t    if rc = 0 then do;          \r\n\t\t\t    did = dopen(fref);          \r\n\t\t    end;          \r\n\t\t    else do;          \r\n\t\t\t    length msg $200.;          \r\n    \t\t\tmsg = sysmsg();          \r\n\t    \t\tput msg=;          \r\n\t\t    \tdid = .;          \r\n    \t\tend;          \r\n          \r\n\t\t    if did <= 0 then          \r\n\t\t\t    put 'ERROR: unable to open compute directory.';\r\n          \r\n\t\t    dnum = dnum(did);          \r\n\t\t    regexp = prxparse(\"&pattern\");\r\n \t\t    do i = 1 to dnum;          \r\n\t\t\t    filename = dread(did, i);          \r\n\t\t\t    rc = prxmatch(regexp, filename);         \r\n\t\t\t    if (rc > 0) then do;\r\n                    directory = kstrip(directory);\r\n \t    \t\t\tfilename = kstrip(filename);         \r\n\t\t    \t\toutput;          \r\n\t\t\t    end;         \r\n\t\t    end;          \r\n\t    run;\r\n\r\n        /*\r\n            Put all the flows names in the 'flows' macro variable.\r\n        */\r\n        proc sql noprint;\r\n            select \r\n                strip(filename) into :flows separated by '|'\r\n            from\r\n                work.items\r\n            order by\r\n                filename;\r\n        quit;\r\n\r\n        /*\r\n            Remove the items dataset, it is not needed anymore.\r\n        */\r\n        proc datasets library=work nolist;\r\n            delete items;\r\n        quit;\r\n    %end;\r\n    /*\r\n        Count the number of flows in the flows macro variable.\r\n    */\r\n    data _null_;\r\n        call symputx(\"nbrFlows\", count(\"&flows\", '|') + 1);\r\n    run;\r\n%mend directoryContent;\r\n\r\n%macro exportFlowCode(\r\n    contentDirectory=,\r\n    codeDirectory=,\r\n    flowName=,\r\n    contentType=\r\n);\r\n    \r\n    %put NOTE: == Input parameters for macro: exportFlowCode ==;\r\n    %put NOTE: &=contentDirectory;\r\n    %put NOTE: &=codeDirectory;\r\n    %put NOTE: &=flowName;\r\n    %put NOTE: &=contentType;\r\n    %put NOTE: == Input end ==;\r\n    \r\n    /*\r\n        Create the request for the end-point.\r\n\r\n        Documentation: https://developer.sas.com/rest-apis/studioDevelopment/getGeneratedCode\r\n    */\r\n    filename request temp;\r\n    proc json out=request nosastags pretty;\r\n\t    write open object;\r\n\t\t    write values \"reference\";\r\n    \t\twrite open object;\r\n\t    \t\twrite values \"type\" \"&contentType\";\r\n\t\t    \twrite values \"path\" \"&contentDirectory./&flowName\";\r\n\t\t\t    write values \"mediaType\" \"application/vnd.sas.dataflow\";\r\n    \t\twrite close;\t\r\n            /*\r\n                SAS session initialization.\r\n            */\r\n            write values \"initCode\" &initCode;\r\n\t\t    write values \"wrapperCode\" &wrapperCode;\r\n            /*\r\n                SAS Studio autoexec. Only works in case initCode is true.\r\n            */\r\n            write values \"userAutoExec\" &userAutoExec;\r\n\t    write close;\r\n    run;\r\n\r\n    /*\r\n        Call the end-point with the request.\r\n\r\n        Documentation: https://developer.sas.com/rest-apis/studioDevelopment/getGeneratedCode\r\n    */\r\n    filename response temp;\r\n    proc http\r\n        method ='post'\r\n        url = \"&viyaHost./studioDevelopment/code\"\r\n        in = request\r\n    \tout= response\r\n        timeout=&_httpTimeOut\r\n        oauth_bearer = sas_services;\r\n        headers\r\n\t    \t'Content-Type'='application/json;charset=utf-8'\r\n\t\t    'Accept'='application/json';\r\n    run;\r\n\r\n    %if &sys_prochttp_status_code eq 200 %then %do;\r\n        /*\r\n            The HTTP request was successful, process the response file \r\n            and try to create a .sas file.\r\n        */\r\n\r\n        %if not %sysfunc(fexist(_python)) %then %do;\r\n            /*\r\n                Only (re)create the Python code when needed.\r\n            */\r\n            %put NOTE: Python code does not exist, creating python code.;\r\n            \r\n            filename _python temp;\r\n            data _null_;\r\n                file _python lrecl=32676;\r\n                put 'submit;'\r\n                    /\r\n                    / 'import os'\r\n                    / 'import json'\r\n                    /\r\n                    / \"responseLocation = SAS.symget('responseLocation')\"\r\n                    / \"sasFile = SAS.symget('sasFile')\"\r\n                    / \r\n                    / 'try:'\r\n                    / '    if not responseLocation:'\r\n                    / '        raise ValueError(\"ERROR: Macro variable responseLocation is missing or empty.\")'\r\n                    / '    if not sasFile:'\r\n                    / '        raise ValueError(\"ERROR: Macro variable sasFile is missing or empty\")'\r\n                    / '    if not os.path.isfile(responseLocation):'\r\n                    / '        raise FileNotFoundError(f\"ERROR: The file {responseLocation} does not exist.\")'\r\n                    / '    with open(responseLocation, \"r\") as json_file:'\r\n                    / '      try:'\r\n                    / '          data = json.load(json_file)'\r\n                    / '      except json.JSONDecodeError as e:'\r\n                    / '          raise ValueError(f\"ERROR: Invalid JSON format: {e}\")'\r\n                    / '    if not isinstance(data, dict):'\r\n                    / '        raise TypeError(\"ERROR: JSON root element must be an object\")'\r\n                    / '    if \"code\" not in data:'\r\n                    / '        raise KeyError(\"ERROR: JSON does not contain the required key: CODE\")'\r\n                    / \"    if not isinstance(data['code'], str):\"\r\n                    / '        raise TypeError(\"ERROR: The code element must be a string.\")'\r\n                    / \"    if not data['code'].strip():\"\r\n                    / '        raise ValueError(\"ERROR: The code element is empty.\")'\r\n                    / '    with open(sasFile, \"w\") as codeFile:'\r\n                    / \"        codeFile.write(data['code'])\"\r\n                    / '    print(f\"{sasFile} file successfully created.\")'\r\n                    / 'except Exception as err:'\r\n                    / '    print(f\"Exception caught: {err}\")'\r\n                    / 'endsubmit;'\r\n            run;\r\n        %end;\r\n        %else %do;\r\n            /*\r\n                Re-using the existing Python code.\r\n            */\r\n            %put NOTE: Python code already exists, re-using it.;\r\n        %end;\r\n\r\n        /*\r\n            Create the variables used by the python code.\r\n        */\r\n        data _null_;\r\n\t\t    call symputx('responseLocation', strip(pathname('response')));\r\n            call symputx('sasFile', \"&codeDirectory./&flowName..sas\");\r\n\t    run;\r\n\r\n        /*\r\n            Run the Pyhon code.\r\n        */\r\n        proc python;\r\n            %inc _python;\r\n        run;\r\n        \r\n        /*\r\n            We will be re-using the Python code.\r\n        */\r\n        *filename _python clear;\r\n    %end;\r\n    %else %do;\r\n        %put ERROR: Unable to generated code for &contentDirectory./&flowName;\r\n\r\n        /*\r\n            Try to read the error message from the response file.\r\n        */\r\n        %if %sysfunc(fexist(response)) %then %do;\r\n            libname response json;\r\n            %if %sysfunc(exist(response.ERRORS_ERRORS, data)) %then %do;\r\n                proc sql noprint;\r\n                    select \r\n                        strip(message) into :errorMessage\r\n                    from\r\n                        response.ERRORS_ERRORS;\r\n                quit;\r\n                %put ERROR: &errorMessage;\r\n            %end;\r\n            %else %do;\r\n                %put ERROR: Unable to retrieve the error message.;\r\n            %end;\r\n            libname response clear;\r\n        %end;\r\n        %else %do;\r\n            %put ERROR: No error message response file received.;\r\n        %end;\r\n    %end;\r\n\r\n    filename request clear;\r\n    filename response clear;\r\n%mend exportFlowCode;\r\n\r\n%macro processFlows;\r\n    \r\n    %put NOTE: == Input parameters for macro: processFlows ==;\r\n    %put NOTE: == Input end ==; \r\n    /*\r\n        Only start processing when the directory the generated sas code needs to be\r\n        written to is a physical one.\r\n    */\r\n    %if &codePathType eq sasserver %then %do;\r\n        %directoryContent(\r\n            contentType=&flowPathType\r\n        );\r\n        %if \"&flows\" ne \"\" %then %do;\r\n            %let index = 1;\r\n            %do %while (%qscan(&flows, &index, '|') ne %str());\r\n                %let flow = %qscan(&flows, &index, '|');\r\n                %put NOTE: Processing flow (&index of &nbrFlows): &flow;\r\n\r\n                %exportFlowCode(\r\n                    contentDirectory=&flowPath,\r\n                    codeDirectory=&codePath,\r\n                    flowName=&flow,\r\n                    contentType=&flowPathType\r\n                );\r\n                %let index = %eval(&index + 1);\r\n            %end;\r\n            /*\r\n                Correct for the last increment.\r\n            */\r\n            %let index = %eval(&index - 1);\r\n            %put NOTE: Number of flows processed: &index;\r\n        %end;\r\n        %else %do;\r\n            %put WARNING: No flow(s) to process.;\r\n        %end;\r\n    %end;\r\n    %else %do;\r\n        %put ERROR: The custom step only supports physical directories to write to .sas file to.;\r\n    %end;\r\n%mend processFlows;\r\n%processFlows;\r\n\r\n/*\r\n    Remove all macro variables from memory.\r\n*/\r\n%symdel viyaHost /NOWARN;\r\n%symdel flowPath /NOWARN;\r\n%symdel codePath /NOWARN;\r\n%symdel codePathType /NOWARN;\r\n%symdel userAutoExec /NOWARN;\r\n%symdel wrapperCode /NOWARN;\r\n%symdel initCode /NOWARN;\r\n%symdel flowPathType /NOWARN;\r\n%symdel flows /NOWARN;\r\n%symdel nbrFlows /NOWARN;\r\n\r\n/*\r\n    Remove all macros from memory.\r\n*/\r\n%sysmacdelete directoryContent / NOWARN;\r\n%sysmacdelete exportFlowCode / NOWARN;\r\n%sysmacdelete processFlows / NOWARN;"}}
