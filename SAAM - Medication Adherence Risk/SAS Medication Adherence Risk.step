{"description":"","displayName":"SAS Medication Adherence Risk.step","eTag":"\"kku97ltlgs\"","flowMetadata":{"inputPorts":[{"name":"pharmacy_clms","displayName":"Pharmacy claims data","description":"","minEntries":1,"maxEntries":1,"type":"table","id":"pharmacy_clms","label":"Pharmacy claims data:"},{"name":"member_data","displayName":"Member data","description":"","minEntries":1,"maxEntries":1,"type":"table","id":"member_data","label":"Member data:"},{"name":"drug_map","displayName":"Drug lookup data","description":"","minEntries":1,"maxEntries":1,"type":"table","id":"drug_map","label":"Drug map data:"},{"name":"inpt_data","displayName":"Facility stays data","description":"","minEntries":1,"maxEntries":1,"type":"table","id":"inpt_data","label":"Facility stays data:"},{"name":"sdoh_data","displayName":"Social determinant of health data","description":"","minEntries":1,"maxEntries":1,"type":"table","id":"sdoh_data","label":"Social determinant data:"},{"name":"pts_to_score","displayName":"Patients to score","description":"","minEntries":0,"maxEntries":1,"type":"table","id":"pts_to_score","label":"Patients to Score data:"}],"outputPorts":[]},"metadataVersion":1,"name":"SAS Medication Adherence Risk.step","properties":{},"templates":{"SAS":"/* SAS templated code goes here */\n\n%macro run_model_code();\n\t%medad_gui_prep();\n\t\n\t%if &GUIprepreturn > 0 %then %do;\n\t\t%local workdir ;\n   \t\t%let workdir=%sysfunc(pathname(WORK)) ;\n/* \t\t%Error_Messages; */\n/*  \t \t%load_json_to_sas_simple(jsonf = &workdir./error_messages.json, */\n/*                         expected_name = ErrorMessages, */\n/*                         sasdsname = ErrorMessages); */\n/* \t\t%get_error_message(table= WORK.ErrorMessages, ID= GUI_PREP&GUIprepreturn., ReturnVal = GUIERROR); */\n\n\t%if &GUIprepreturn =1 %then %do;\n        %hpimedadh_throw_error();\n        %hpimedadh_catch_error(msgkey = med_adh_risk_step_variables_error_msg);\n        %let &returnmsg = %hpimedadh_assign_smd_var(msgkey = med_adh_risk_step_variables_error_msg, IN_DATA_STEP = N);\n\t%end;\n\n\t%if &GUIprepreturn =2 %then %do;\n        %hpimedadh_throw_error();\n        %hpimedadh_catch_error(msgkey = med_adh_risk_step_storage_error_msg);\n        %let &returnmsg = %hpimedadh_assign_smd_var(msgkey = med_adh_risk_step_storage_error_msg, IN_DATA_STEP = N);\n\t%end;\n\n/* \t\t%put &GUIERROR.; */\n\t\t%goto exitearly;\n\t%end;\n\t\n\t%medad_write_json(loc = &sasloc., folder = &jsonpath. , fname =  &keyID._JSON_INPUT ); \n\t\n\t%predict_med_adherence(jsonf = &jsonpath./&keyID._JSON_INPUT.json, prerun = &p_prerun);\n\t\n\t%exitearly:\n\n%mend;\n%run_model_code();\n\n\n\n\n\n"},"type":"code","ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"overview\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Overview\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text2\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"SAS Studio Custom Step for executing SAS Medication Adherence Risk. \\n\\nThe SAS Medication Adherence Risk product uses machine learning to identify patients’ risk of being non-adherent based on past patient behavior, patient demographics, and social determinant data. The model produces population-specific score code which is used to identify patients’ risk of being non-adherent.   \",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"purpose\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Intended Use and Limitations on Use\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"text4\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"Intended Use:\\nSAS Medication Adherence Risk is intended solely to create and develop models for use in research relating to the analysis of medication non-adherence. The Offering provides a modeling pipeline that enables Customers to develop models using their own data. It does not include any pretrained models. The Offering is designed to assist with developing models that recognize patterns and risk factors associated with medication adherence behaviors.  Customer's use of model outputs from any model developed with this Offering should be subject to meaningful human review.\\n\\nLimitations on Use:\\nSAS does not intend for SAS Medication Adherence Risk to be used, and Customer agrees not to use the Offering, for clinical decision-making, patient care, or any regulated medical application. The Offering is not intended to replace medical professionals in the identification, assessment, or interpretation of medical data.  Statistical models, such as those developed using this Offering, may produce false positives or false negatives.  Customer is solely responsible for all results, outcomes or effects of development and deployment of any resulting models.  Customer is also solely responsible for ensuring that any resulting models are used in compliance with applicable laws and regulations.\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"prereq\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Prerequisites\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"prereqText\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"A license for SAS Medication Adherence Risk is required. \\n\\nPrerequisites:  Tested on Viya version Stable 2024.08\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"usageSection\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Usage Notes\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"usageText\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"1. All data must exist in a SAS library\\n2. Libraries must be defined prior to interacting with the User Interface\\n3. Certain variables that are used to join datasets must have consistent names across datasets in which they appear. Variables include: \\n     a. Member ID (exists in Pharmacy Claims, Member Information, Patients to Score, and Inpatient Stays)\\n     b. Drug Code (exists in Pharmacy Claims, Patients to Score, and Drug Look Up)\\n     c. Drug Class (exists in Pharmacy Claims and Drug Look up)\\n     d. Drug Fill Date (exists in Pharmacy Claims and Patients to Score)\\n     e. Member State (exists in Member Information and SDOH Data)\\n     f. Member County or Zip (exists in Member Information and SDOH Data)\\n4. Patients to Score data and related data field inputs are required for scoring and are not used for model training. The fields are only available when \\\"Use previously trained model and score patients\\\" is the selected process request.\\n5. When running this step in a flow, an input port must be added on the step node to connect the Patients to Score data.\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"DocSection\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Documentation\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"DocText\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"SAS Medication Adherence Risk documentation (https://go.documentation.sas.com/doc/en/aaimhpmacdc/v_001/aaimhpmawlcm/home.htm)\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"changelogSection\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Change Log\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"text3\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"* Version: 1.0 (19Mar2026)\\n      - Initial version\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"DS_VAR\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Data\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"DS_Pharmacy_Section\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Pharmacy Data\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"pharmacy_clms\",\n\t\t\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\t\t\"label\": \"Pharmacy claims data:\",\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"p_memID_pharm\",\n\t\t\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\t\t\"label\": \"Member ID:\",\n\t\t\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 2,\n\t\t\t\t\t\t\t\"table\": \"pharmacy_clms\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"p_claim_id\",\n\t\t\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\t\t\"label\": \"Claim ID:\",\n\t\t\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 2,\n\t\t\t\t\t\t\t\"table\": \"pharmacy_clms\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"p_ord_provid\",\n\t\t\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\t\t\"label\": \"Prescribing provider ID:\",\n\t\t\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"indent\": 2,\n\t\t\t\t\t\t\t\"table\": \"pharmacy_clms\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t