{"creationTimeStamp":"2026-06-10T11:02:01.261516Z","createdBy":"albudn","modifiedTimeStamp":"2026-06-11T07:46:35.406123Z","modifiedBy":"albudn","id":"ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","name":"SDG - synthetic data utility audit.step","displayName":"SDG - synthetic data utility audit.step","localDisplayName":"SDG - synthetic data utility audit.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385/copy","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","uri":"/dataFlows/steps/ed77b8a4-6da6-4f3e-9a26-b7c26d60a385","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"realTable","displayName":"realTable","localDisplayName":"realTable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"},{"name":"synthTable","displayName":"synthTable","localDisplayName":"synthTable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"about\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"title1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Synthetic Data Fidelity & Utility Audit\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"intro_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"This custom step compares a real dataset against a synthetic dataset to produce a composite similarity score. It evaluates data fidelity across four dimensions: numeric univariate similarity (mean, median, standard deviation), categorical univariate similarity (total variation distance and Jensen–Shannon divergence), categorical relationship fidelity (pairwise Cramér's V comparison), and numeric relationship fidelity (pairwise Spearman correlation comparison). Each dimension produces a detail table for drill-through analysis, and the results are combined into weighted statistical and relational similarity scores — proportional to the number of numeric and categorical variables — giving a single overall similarity percentage. An optional filter condition allows evaluation on specific subsets of the data.\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"Parameters\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Parameters\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"Parameters_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"- Real Table — the two-level name of the real (original) dataset to use as the baseline for comparison (e.g. CASUSER.REAL).\\n- Synthetic Table — the two-level name of the synthetic dataset to evaluate against the real data (e.g. CASUSER.SYNTH).\\n- Filter Condition — an optional WHERE expression to subset both tables before evaluation (e.g. bad=1). Leave blank to run against the full tables.\\n- outLib — the output library where all five result tables will be written (e.g. WORK or CASUSER). Defaults to WORK. \\n\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"References_id\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"References\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"References_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"The framework is mentioned in a presentation at SAS Innovate 2026 - watch here: https://www.youtube.com/watch?v=0waLptixaOk&list=PLVBcK_IpFVi-BXicJ5ZMcXuPNQTphJuhv&index=146&t=1s \",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"About\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"About\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"About_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"Version: 1.0 (June 2026)\\n\\nContact: Alina Budnyuk \\n(alina.budnyuk@sas.com)\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Controls\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"realTable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table 1- real data\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"filter\": false\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"synthTable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table 2 - synthetic data\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"filter\": false\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"outLib\",\n\t\t\t\t\t\"type\": \"libraryselector\",\n\t\t\t\t\t\"label\": \"Output Library\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"filterCondition\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Filter Condition\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"realTable\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"realTable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"synthTable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"outLib\": \"WORK\",\n\t\t\"filterCondition\": []\n\t},\n\t\"promptHierarchies\": []\n}","localUi":"{\"pages\":[{\"children\":[{\"children\":[{\"id\":\"intro_text\",\"text\":\"This custom step compares a real dataset against a synthetic dataset to produce a composite similarity score. It evaluates data fidelity across four dimensions: numeric univariate similarity (mean, median, standard deviation), categorical univariate similarity (total variation distance and Jensen–Shannon divergence), categorical relationship fidelity (pairwise Cramér's V comparison), and numeric relationship fidelity (pairwise Spearman correlation comparison). Each dimension produces a detail table for drill-through analysis, and the results are combined into weighted statistical and relational similarity scores — proportional to the number of numeric and categorical variables — giving a single overall similarity percentage. An optional filter condition allows evaluation on specific subsets of the data.\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"title1\",\"label\":\"Synthetic Data Fidelity \\u0026 Utility Audit\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"Parameters_text\",\"text\":\"- Real Table — the two-level name of the real (original) dataset to use as the baseline for comparison (e.g. CASUSER.REAL).\\n- Synthetic Table — the two-level name of the synthetic dataset to evaluate against the real data (e.g. CASUSER.SYNTH).\\n- Filter Condition — an optional WHERE expression to subset both tables before evaluation (e.g. bad=1). Leave blank to run against the full tables.\\n- outLib — the output library where all five result tables will be written (e.g. WORK or CASUSER). Defaults to WORK. \\n\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"Parameters\",\"label\":\"Parameters\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"References_text\",\"text\":\"The framework is mentioned in a presentation at SAS Innovate 2026 - watch here: https://www.youtube.com/watch?v=0waLptixaOk\\u0026list=PLVBcK_IpFVi-BXicJ5ZMcXuPNQTphJuhv\\u0026index=146\\u0026t=1s \",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"References_id\",\"label\":\"References\",\"open\":false,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"About_text\",\"text\":\"Version: 1.0 (June 2026)\\n\\nContact: Alina Budnyuk \\n(alina.budnyuk@sas.com)\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"About\",\"label\":\"About\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"about\",\"label\":\"About\",\"type\":\"page\"},{\"children\":[{\"filter\":false,\"id\":\"realTable\",\"label\":\"Input table 1- real data\",\"placeholder\":\"\",\"required\":true,\"type\":\"inputtable\",\"visible\":\"\"},{\"filter\":false,\"id\":\"synthTable\",\"label\":\"Input table 2 - synthetic data\",\"placeholder\":\"\",\"required\":true,\"type\":\"inputtable\",\"visible\":\"\"},{\"id\":\"outLib\",\"label\":\"Output Library\",\"placeholder\":\"\",\"required\":false,\"type\":\"libraryselector\",\"visible\":\"\"},{\"columntype\":\"a\",\"id\":\"filterCondition\",\"include\":null,\"label\":\"Filter Condition\",\"max\":null,\"min\":null,\"order\":false,\"table\":\"realTable\",\"type\":\"columnselector\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"Controls\",\"type\":\"page\"}],\"promptHierarchies\":[],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"filterCondition\":[],\"outLib\":\"WORK\",\"realTable\":{\"library\":\"\",\"table\":\"\"},\"synthTable\":{\"library\":\"\",\"table\":\"\"}}}","templates":{"SAS":"/*============================================================\r\n  SYNTHETIC DATA COMPARISON — Custom Step Macro\r\n  ============================================================\r\n  PURPOSE\r\n    Compare a real table against a synthetic table across\r\n    four evaluation dimensions and produce a composite\r\n    similarity score.\r\n\r\n  DIMENSIONS\r\n    1. Numeric Univariate    — mean / median / std comparison\r\n    2. Categorical Univariate — TVD + JSD on category frequencies\r\n    3. Categorical Relationship — pairwise Cramér's V delta\r\n    4. Numeric Relationship    — pairwise Spearman ρ delta\r\n\r\n  PARAMETERS\r\n    realTable        Two-level name  (e.g. CASUSER.ORIGINAL)\r\n    synthTable       Two-level name  (e.g. CASUSER.SYNTHETIC)\r\n    filterCondition  Optional WHERE  (e.g. bad=1)\r\n    outLib           Output library  (default WORK)\r\n   \r\n  OUTPUT TABLES  (all written to &outLib.)\r\n    detail_num_univariate\r\n    detail_cat_univariate\r\n    detail_cat_relationship\r\n    detail_num_relationship\r\n    similarity_scores\r\n============================================================*/\r\n\r\n%macro syntheticDataComparison(\r\n    realTable       = ,\r\n    synthTable      = ,\r\n    filterCondition = ,\r\n    outLib          = \r\n);\r\n\r\n/* ============================================================\r\n   0.  SETUP\r\n   ============================================================ */\r\n%local wc char_vars num_vars nChar nNum i var\r\n       sc_numUni sc_catUni sc_catRel sc_numRel;\r\noptions nosyntaxcheck;\r\n\r\n/* --- reusable WHERE-clause dataset option --- */\r\n%if %length(&filterCondition.) > 0 %then\r\n    %let wc = (where=(&filterCondition.));\r\n%else\r\n    %let wc = ;\r\n\r\n/* --- discover character variables from the real table --- */\r\nproc sql noprint;\r\n    select name into :char_vars separated by ' '\r\n    from dictionary.columns\r\n    where libname = upcase(scan(\"&realTable.\", 1, '.'))\r\n      and memname = upcase(scan(\"&realTable.\", 2, '.'))\r\n      and type    = 'char';\r\nquit;\r\n%let nChar = %sysfunc(countw(&char_vars.));\r\n\r\n/* --- discover numeric variables from the real table --- */\r\nproc sql noprint;\r\n    select name into :num_vars separated by ' '\r\n    from dictionary.columns\r\n    where libname = upcase(scan(\"&realTable.\", 1, '.'))\r\n      and memname = upcase(scan(\"&realTable.\", 2, '.'))\r\n      and type    = 'num';\r\nquit;\r\n%let nNum = %sysfunc(countw(&num_vars.));\r\n\r\n/* initialise component scores to missing                    */\r\n/* mean() in the final step will skip any that stay missing  */\r\n%let sc_numUni = .;\r\n%let sc_catUni = .;\r\n%let sc_catRel = .;\r\n%let sc_numRel = .;\r\n\r\n\r\n/* ============================================================\r\n   1.  NUMERIC UNIVARIATE SIMILARITY\r\n       mean / median / std per numeric variable\r\n   ============================================================ */\r\n%if &nNum. > 0 %then %do;\r\n\r\n    proc means data=&realTable.&wc. noprint;\r\n        var &num_vars.;\r\n        output out=_nv_real mean= median= std= / autoname;\r\n    run;\r\n\r\n    proc means data=&synthTable.&wc. noprint;\r\n        var &num_vars.;\r\n        output out=_nv_fake mean= median= std= / autoname;\r\n    run;\r\n\r\n    proc transpose data=_nv_real(drop=_TYPE_ _FREQ_)\r\n         out=_nv_real_t(rename=(_NAME_=statistic col1=real_value));\r\n    run;\r\n    proc transpose data=_nv_fake(drop=_TYPE_ _FREQ_)\r\n         out=_nv_fake_t(rename=(_NAME_=statistic col1=fake_value));\r\n    run;\r\n\r\n    proc sort data=_nv_real_t; by statistic; run;\r\n    proc sort data=_nv_fake_t; by statistic; run;\r\n\r\n    data &outLib..detail_num_univariate;\r\n        merge _nv_real_t\r\n              _nv_fake_t;\r\n        by statistic;\r\n\r\n        /* parse the autoname: e.g. income_Mean → variable=income, stat_type=Mean */\r\n        length variable $32 stat_type $10;\r\n        stat_type = scan(statistic, -1, '_');\r\n        variable  = substr(statistic, 1,\r\n                      length(statistic) - length(stat_type) - 1);\r\n\r\n        /* similarity: 100 % when identical, lower when different */\r\n        denom          = max(abs(real_value), abs(fake_value), 1);\r\n        pct_similarity = 100 - 100 * abs(real_value - fake_value) / denom;\r\n\r\n        drop denom;\r\n    run;\r\n\r\n    /* aggregate to single component score */\r\n    proc means data=&outLib..detail_num_univariate noprint;\r\n        var pct_similarity;\r\n        output out=_nv_agg mean=_mean;\r\n    run;\r\n\r\n    data _null_;\r\n        set _nv_agg;\r\n        call symputx('sc_numUni', _mean / 100);\r\n    run;\r\n\r\n%end;\r\n%else %do;\r\n    /* no numeric variables — empty shell */\r\n    data &outLib..detail_num_univariate;\r\n        length statistic $64 variable $32 stat_type $10;\r\n        call missing(real_value, fake_value, pct_similarity);\r\n        stop;\r\n    run;\r\n%end;\r\n\r\n\r\n/* ============================================================\r\n   2.  CATEGORICAL UNIVARIATE SIMILARITY\r\n       TVD + JSD on per-variable frequency distributions\r\n   ============================================================ */\r\n%if &nChar. > 0 %then %do;\r\n\r\n    /* --- real frequencies in long form --- */\r\n    %do i = 1 %to &nChar.;\r\n        %let var = %scan(&char_vars., &i.);\r\n\r\n        proc freq data=&realTable.&wc. noprint;\r\n            tables &var. / out=_cf_r_&i.;\r\n        run;\r\n\r\n        data _cf_r_&i.(keep=varname category PERCENT);\r\n            length varname $32 category $256;\r\n            set _cf_r_&i.;\r\n            varname  = \"&var.\";\r\n            category = strip(&var.);\r\n        run;\r\n    %end;\r\n\r\n    data _cf_real;\r\n        set %do i = 1 %to &nChar.; _cf_r_&i. %end;;\r\n    run;\r\n\r\n    /* --- synthetic frequencies in long form --- */\r\n    %do i = 1 %to &nChar.;\r\n        %let var = %scan(&char_vars., &i.);\r\n\r\n        proc freq data=&synthTable.&wc. noprint;\r\n            tables &var. / out=_cf_s_&i.;\r\n        run;\r\n\r\n        data _cf_s_&i.(keep=varname category PERCENT);\r\n            length varname $32 category $256;\r\n            set _cf_s_&i.;\r\n            varname  = \"&var.\";\r\n            category = strip(&var.);\r\n        run;\r\n    %end;\r\n\r\n    data _cf_fake;\r\n        set %do i = 1 %to &nChar.; _cf_s_&i. %end;;\r\n    run;\r\n\r\n    /* --- merge by varname AND category (was varname only — fixed) --- */\r\n    proc sort data=_cf_real; by varname category; run;\r\n    proc sort data=_cf_fake; by varname category; run;\r\n\r\n    data _cf_merged;\r\n        merge _cf_real(rename=(PERCENT=real_pct))\r\n              _cf_fake(rename=(PERCENT=fake_pct));\r\n        by varname category;\r\n\r\n        real_p = coalesce(real_pct, 0) / 100;\r\n        fake_p = coalesce(fake_pct, 0) / 100;\r\n\r\n        /* TVD contribution */\r\n        tvd_i = abs(real_p - fake_p);\r\n\r\n        /* JSD components */\r\n        M = (real_p + fake_p) / 2;\r\n\r\n        if real_p > 0 and M > 0 then kl_r = real_p * log2(real_p / M);\r\n        else kl_r = 0;\r\n\r\n        if fake_p > 0 and M > 0 then kl_f = fake_p * log2(fake_p / M);\r\n        else kl_f = 0;\r\n    run;\r\n\r\n    /* summarise per variable */\r\n    proc means data=_cf_merged noprint;\r\n        by varname;\r\n        var tvd_i kl_r kl_f;\r\n        output out=_cf_summary\r\n            sum(tvd_i) = tvd_raw\r\n            sum(kl_r)  = kl_real\r\n            sum(kl_f)  = kl_fake;\r\n    run;\r\n\r\n    data &outLib..detail_cat_univariate(keep=varname TVD JSD);\r\n        set _cf_summary;\r\n        JSD = sqrt(0.5 * (kl_real + kl_fake));\r\n        TVD = 0.5 * tvd_raw;\r\n    run;\r\n\r\n    /* aggregate to single component score */\r\n    proc means data=&outLib..detail_cat_univariate mean max noprint;\r\n        var TVD JSD;\r\n        output out=_cf_agg\r\n            mean = Mean_TVD Mean_JSD\r\n            max  = Max_TVD  Max_JSD;\r\n    run;\r\n\r\n    data _null_;\r\n        set _cf_agg;\r\n        _tvd = mean((1 - Mean_TVD), (1 - Max_TVD));\r\n        _jsd = mean((1 - Mean_JSD), (1 - Max_JSD));\r\n        call symputx('sc_catUni', mean(_tvd, _jsd));\r\n    run;\r\n\r\n%end;\r\n%else %do;\r\n    data &outLib..detail_cat_univariate;\r\n        length varname $32;\r\n        call missing(TVD, JSD);\r\n        stop;\r\n    run;\r\n%end;\r\n\r\n\r\n/* ============================================================\r\n   3.  CATEGORICAL RELATIONSHIP FIDELITY  (Cramér's V)\r\n       Requires >= 2 character variables\r\n   ============================================================ */\r\n%if &nChar. >= 2 %then %do;\r\n\r\n    /* real pairwise Cramér's V */\r\n    ods exclude all;\r\n    proc freq data=&realTable.&wc.;\r\n        tables (&char_vars.) * (&char_vars.) / chisq;\r\n        ods output ChiSq = _cv_real_chi;\r\n    run;\r\n    ods exclude none;\r\n\r\n    data _cv_real(keep=Var1 Var2 Real_V);\r\n        length Var1 Var2 $32;\r\n        set _cv_real_chi(where=(statistic = \"Cramer's V\"));\r\n        Var1   = scan(table, 2, ' ');\r\n        Var2   = scan(table, 4, ' ');\r\n        Real_V = value;\r\n        if Var1 < Var2;   /* upper triangle only */\r\n    run;\r\n\r\n    /* synthetic pairwise Cramér's V */\r\n    ods exclude all;\r\n    proc freq data=&synthTable.&wc.;\r\n        tables (&char_vars.) * (&char_vars.) / chisq;\r\n        ods output ChiSq = _cv_fake_chi;\r\n    run;\r\n    ods exclude none;\r\n\r\n    data _cv_fake(keep=Var1 Var2 Fake_V);\r\n        length Var1 Var2 $32;\r\n        set _cv_fake_chi(where=(statistic = \"Cramer's V\"));\r\n        Var1   = scan(table, 2, ' ');\r\n        Var2   = scan(table, 4, ' ');\r\n        Fake_V = value;\r\n        if Var1 < Var2;\r\n    run;\r\n\r\n    proc sort data=_cv_real; by Var1 Var2; run;\r\n    proc sort data=_cv_fake; by Var1 Var2; run;\r\n\r\n    data &outLib..detail_cat_relationship;\r\n        merge _cv_real _cv_fake;\r\n        by Var1 Var2;\r\n        if Real_V = . then Real_V = 0;\r\n        if Fake_V = . then Fake_V = 0;\r\n        Abs_Delta = abs(Real_V - Fake_V);\r\n    run;\r\n\r\n    /* aggregate to single component score */\r\n    proc means data=&outLib..detail_cat_relationship noprint;\r\n        var Abs_Delta;\r\n        output out=_cv_agg mean=_mean;\r\n    run;\r\n\r\n    data _null_;\r\n        set _cv_agg;\r\n        call symputx('sc_catRel', 1 - _mean);\r\n    run;\r\n\r\n%end;\r\n%else %do;\r\n    data &outLib..detail_cat_relationship;\r\n        length Var1 Var2 $32;\r\n        call missing(Real_V, Fake_V, Abs_Delta);\r\n        stop;\r\n    run;\r\n%end;\r\n\r\n\r\n/* ============================================================\r\n   4.  NUMERIC RELATIONSHIP FIDELITY  (Spearman)\r\n       Requires >= 2 numeric variables.\r\n       FIX: both matrices are pivoted to long form BEFORE\r\n       the merge so column names cannot collide.\r\n   ============================================================ */\r\n%if &nNum. >= 2 %then %do;\r\n\r\n    proc corr data=&realTable.&wc. spearman noprint outp=_sp_real;\r\n        var &num_vars.;\r\n    run;\r\n    proc corr data=&synthTable.&wc. spearman noprint outp=_sp_fake;\r\n        var &num_vars.;\r\n    run;\r\n\r\n    /* pivot REAL matrix → long */\r\n    data _sp_real_long(keep=Var1 Var2 Real_Corr);\r\n        set _sp_real(where=(_TYPE_ = 'CORR'));\r\n        array v {*} &num_vars.;\r\n        length Var1 Var2 $32;\r\n        Var1 = _NAME_;\r\n        do _j = 1 to dim(v);\r\n            Var2      = vname(v[_j]);\r\n            Real_Corr = v[_j];\r\n            if Var1 < Var2 then output;\r\n        end;\r\n    run;\r\n\r\n    /* pivot FAKE matrix → long */\r\n    data _sp_fake_long(keep=Var1 Var2 Fake_Corr);\r\n        set _sp_fake(where=(_TYPE_ = 'CORR'));\r\n        array v {*} &num_vars.;\r\n        length Var1 Var2 $32;\r\n        Var1 = _NAME_;\r\n        do _j = 1 to dim(v);\r\n            Var2      = vname(v[_j]);\r\n            Fake_Corr = v[_j];\r\n            if Var1 < Var2 then output;\r\n        end;\r\n    run;\r\n\r\n    proc sort data=_sp_real_long; by Var1 Var2; run;\r\n    proc sort data=_sp_fake_long; by Var1 Var2; run;\r\n\r\n    data &outLib..detail_num_relationship;\r\n        merge _sp_real_long _sp_fake_long;\r\n        by Var1 Var2;\r\n        if Real_Corr = . then Real_Corr = 0;\r\n        if Fake_Corr = . then Fake_Corr = 0;\r\n        Abs_Delta = min(abs(Real_Corr - Fake_Corr), 1.0);\r\n    run;\r\n\r\n    /* aggregate to single component score */\r\n    proc means data=&outLib..detail_num_relationship noprint;\r\n        var Abs_Delta;\r\n        output out=_sp_agg mean=_mean;\r\n    run;\r\n\r\n    data _null_;\r\n        set _sp_agg;\r\n        call symputx('sc_numRel', 1 - _mean);\r\n    run;\r\n\r\n%end;\r\n%else %do;\r\n    data &outLib..detail_num_relationship;\r\n        length Var1 Var2 $32;\r\n        call missing(Real_Corr, Fake_Corr, Abs_Delta);\r\n        stop;\r\n    run;\r\n%end;\r\n\r\n\r\n/* ============================================================\r\n   5.  FINAL SIMILARITY SCORES\r\n       statistical_similarity  = weighted avg of univariate scores\r\n       relational_similarity   = weighted avg of relationship scores\r\n       weights = number of variables in each class\r\n   ============================================================ */\r\ndata &outLib..similarity_scores;\r\n    format overall_similarity_pct\r\n           statistical_similarity_pct\r\n           relational_similarity_pct\r\n           num_similarity_pct\r\n           char_similarity_pct\r\n           char_corr_pct\r\n           num_corr_pct percent10.3;\r\n\r\n    num_similarity_pct  = &sc_numUni.;\r\n    char_similarity_pct = &sc_catUni.;\r\n    char_corr_pct       = &sc_catRel.;\r\n    num_corr_pct        = &sc_numRel.;\r\n\r\n    /* --- variable counts as weights --- */\r\n    _nw = ifn(num_similarity_pct  = ., 0, &nNum.);\r\n    _cw = ifn(char_similarity_pct = ., 0, &nChar.);\r\n\r\n    if (_nw + _cw) > 0 then\r\n        statistical_similarity_pct =\r\n            (_nw * num_similarity_pct + _cw * char_similarity_pct)\r\n            / (_nw + _cw);\r\n    else\r\n        statistical_similarity_pct = .;\r\n\r\n    /* --- same weighting for relationship scores --- */\r\n    _nw_r = ifn(num_corr_pct  = ., 0, &nNum.);\r\n    _cw_r = ifn(char_corr_pct = ., 0, &nChar.);\r\n\r\n    if (_nw_r + _cw_r) > 0 then\r\n        relational_similarity_pct =\r\n            (_nw_r * num_corr_pct + _cw_r * char_corr_pct)\r\n            / (_nw_r + _cw_r);\r\n    else\r\n        relational_similarity_pct = .;\r\n\r\n    /* --- overall = average of the two composites --- */\r\n    overall_similarity_pct = mean(\r\n        statistical_similarity_pct,\r\n        relational_similarity_pct\r\n    );\r\n\r\n    drop _nw _cw _nw_r _cw_r;\r\nrun;\r\n\r\n\r\n/* ============================================================\r\n   CLEANUP — remove temporary datasets\r\n   ============================================================ */\r\nproc datasets lib=WORK nolist nowarn;\r\n    delete\r\n        _nv_real _nv_fake _nv_real_t _nv_fake_t _nv_agg\r\n        _cf_r_: _cf_s_: _cf_real _cf_fake _cf_merged\r\n        _cf_summary _cf_agg\r\n        _cv_real_chi _cv_fake_chi _cv_real _cv_fake _cv_agg\r\n        _sp_real _sp_fake _sp_real_long _sp_fake_long _sp_agg\r\n    ;\r\nquit;\r\n\r\n\r\n%put NOTE: =====================================================;\r\n%put NOTE: Synthetic Data Comparison Complete                    ;\r\n%put NOTE: Num Univar   : &sc_numUni.                           ;\r\n%put NOTE: Cat Univar   : &sc_catUni.                           ;\r\n%put NOTE: Cat Relation : &sc_catRel.                           ;\r\n%put NOTE: Num Relation : &sc_numRel.                           ;\r\n%put NOTE: Output lib   : &outLib.                              ;\r\n%put NOTE: =====================================================;\r\n\r\n%mend syntheticDataComparison;\r\n\r\n\r\n%syntheticDataComparison(\r\n    realTable       = &realTable,\r\n    synthTable      = &synthTable,\r\n    filterCondition = &filterCondition,\r\n    outLib          = &outLib\r\n);\r\n"}}
