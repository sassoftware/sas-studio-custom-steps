{"creationTimeStamp":"2026-06-19T14:02:11.346809Z","createdBy":"Shubham.Pancholi@sas.com","modifiedTimeStamp":"2026-06-19T14:02:11.346809Z","modifiedBy":"Shubham.Pancholi@sas.com","id":"c89b8fb7-6665-48f1-832c-8e05280f4e3d","name":"TIA - Assess Bias.step","displayName":"TIA - Assess Bias.step","localDisplayName":"TIA - Assess Bias.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d/copy","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","uri":"/dataFlows/steps/c89b8fb7-6665-48f1-832c-8e05280f4e3d","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"inputTable","displayName":"inputTable","localDisplayName":"inputTable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"config\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Configuration\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"inputTable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"filter\": false\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"probabilityVariable\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Predicted Probability Variable\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"sensitiveVariable\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Sensitive Variable\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"targetSection\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Target\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"targetVariable\",\n\t\t\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\t\t\"label\": \"Target Variable\",\n\t\t\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"targetLevel\",\n\t\t\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\t\t\"label\": \"Target Level\",\n\t\t\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\"value\": \"Interval\"\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\"value\": \"Nominal\"\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t],\n\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\t\t\"$targetVariable\",\n\t\t\t\t\t\t\t\t\"!=\",\n\t\t\t\t\t\t\t\t\"\"\n\t\t\t\t\t\t\t]\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"targetEvent\",\n\t\t\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\t\t\"label\": \"Target Event\",\n\t\t\t\t\t\t\t\"items\": {\n\t\t\t\t\t\t\t\t\"ref\": \"targetVariable\"\n\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\t\t\"$targetLevel\",\n\t\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\t\"Nominal\"\n\t\t\t\t\t\t\t]\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"fitStatSection\",\n\t\t\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\t\t\"label\": \"FitStat\",\n\t\t\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\"id\": \"pVars\",\n\t\t\t\t\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\t\t\t\t\"label\": \"P Variables\",\n\t\t\t\t\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\"id\": \"pEvent\",\n\t\t\t\t\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\t\t\t\t\"label\": \"P Event\",\n\t\t\t\t\t\t\t\t\t\"items\": {\n\t\t\t\t\t\t\t\t\t\t\"ref\": \"targetVariable\"\n\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\"id\": \"FitStatDelimiter\",\n\t\t\t\t\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\t\t\t\t\"label\": \"Delimiter\",\n\t\t\t\t\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\"value\": \" (Space)\"\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\"value\": \"; (Semicolon)\"\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\"value\": \"* (Astrisk)\"\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\"value\": \". (Period)\"\n\t\t\t\t\t\t\t\t\t\t},\n\t\t\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\t\"value\": \", (Comma)\"\n\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t],\n\t\t\t\t\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\t\t\t\t\"$pEvent\",\n\t\t\t\t\t\t\t\t\t\t\"!=\",\n\t\t\t\t\t\t\t\t\t\t\"\"\n\t\t\t\t\t\t\t\t\t]\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t]\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"options\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Options\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"cutoff\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Cutoff Ratio\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": false,\n\t\t\t\t\t\"min\": 0,\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"stepsize\": 0.1\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"numBins\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Number Of Bins\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": true,\n\t\t\t\t\t\"min\": 2,\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"stepsize\": 1\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"numCuts\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Number Of Cuts\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": true,\n\t\t\t\t\t\"min\": 2,\n\t\t\t\t\t\"max\": 100,\n\t\t\t\t\t\"stepsize\": 1\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"selectionDepth\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Selection Depth\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": true,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"max\": 100,\n\t\t\t\t\t\"stepsize\": 1\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"freq\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Frequency\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"weight\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Weight\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"inputTable\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"inputTable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"probabilityVariable\": [],\n\t\t\"sensitiveVariable\": [],\n\t\t\"targetVariable\": [],\n\t\t\"targetLevel\": {\n\t\t\t\"value\": \"Interval\"\n\t\t},\n\t\t\"targetEvent\": null,\n\t\t\"pVars\": [],\n\t\t\"pEvent\": null,\n\t\t\"FitStatDelimiter\": {\n\t\t\t\"value\": \" (Space)\"\n\t\t},\n\t\t\"cutoff\": 0.5,\n\t\t\"numBins\": 20,\n\t\t\"numCuts\": 100,\n\t\t\"selectionDepth\": 10,\n\t\t\"freq\": [],\n\t\t\"weight\": []\n\t},\n\t\"promptHierarchies\": []\n}","localUi":"{\"pages\":[{\"children\":[{\"filter\":false,\"id\":\"inputTable\",\"label\":\"Input table\",\"placeholder\":\"\",\"required\":true,\"type\":\"inputtable\",\"visible\":\"\"},{\"columntype\":\"a\",\"id\":\"probabilityVariable\",\"include\":null,\"label\":\"Predicted Probability Variable\",\"max\":null,\"min\":1,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"},{\"columntype\":\"a\",\"id\":\"sensitiveVariable\",\"include\":null,\"label\":\"Sensitive Variable\",\"max\":1,\"min\":1,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"},{\"children\":[{\"columntype\":\"a\",\"id\":\"targetVariable\",\"include\":null,\"label\":\"Target Variable\",\"max\":1,\"min\":1,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"},{\"id\":\"targetLevel\",\"items\":[{\"value\":\"Interval\"},{\"value\":\"Nominal\"}],\"label\":\"Target Level\",\"placeholder\":\"\",\"required\":true,\"type\":\"dropdown\",\"visible\":[\"$targetVariable\",\"!=\",\"\"]},{\"id\":\"targetEvent\",\"items\":{\"ref\":\"targetVariable\"},\"label\":\"Target Event\",\"placeholder\":\"\",\"required\":false,\"type\":\"dropdown\",\"visible\":[\"$targetLevel\",\"=\",\"Nominal\"]},{\"children\":[{\"columntype\":\"a\",\"id\":\"pVars\",\"include\":null,\"label\":\"P Variables\",\"max\":1,\"min\":null,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"},{\"id\":\"pEvent\",\"items\":{\"ref\":\"targetVariable\"},\"label\":\"P Event\",\"placeholder\":\"\",\"required\":false,\"type\":\"dropdown\",\"visible\":\"\"},{\"id\":\"FitStatDelimiter\",\"items\":[{\"value\":\" (Space)\"},{\"value\":\"; (Semicolon)\"},{\"value\":\"* (Astrisk)\"},{\"value\":\". (Period)\"},{\"value\":\", (Comma)\"}],\"label\":\"Delimiter\",\"placeholder\":\"\",\"required\":true,\"type\":\"dropdown\",\"visible\":[\"$pEvent\",\"!=\",\"\"]}],\"id\":\"fitStatSection\",\"label\":\"FitStat\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"targetSection\",\"label\":\"Target\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"config\",\"label\":\"Configuration\",\"type\":\"page\"},{\"children\":[{\"id\":\"cutoff\",\"integer\":false,\"label\":\"Cutoff Ratio\",\"max\":1,\"min\":0,\"required\":false,\"stepsize\":0.1,\"type\":\"numstepper\"},{\"id\":\"numBins\",\"integer\":true,\"label\":\"Number Of Bins\",\"max\":null,\"min\":2,\"required\":false,\"stepsize\":1,\"type\":\"numstepper\"},{\"id\":\"numCuts\",\"integer\":true,\"label\":\"Number Of Cuts\",\"max\":100,\"min\":2,\"required\":false,\"stepsize\":1,\"type\":\"numstepper\"},{\"id\":\"selectionDepth\",\"integer\":true,\"label\":\"Selection Depth\",\"max\":100,\"min\":1,\"required\":false,\"stepsize\":1,\"type\":\"numstepper\"},{\"columntype\":\"a\",\"id\":\"freq\",\"include\":null,\"label\":\"Frequency\",\"max\":1,\"min\":null,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"},{\"columntype\":\"a\",\"id\":\"weight\",\"include\":null,\"label\":\"Weight\",\"max\":1,\"min\":null,\"order\":false,\"table\":\"inputTable\",\"type\":\"columnselector\",\"visible\":\"\"}],\"id\":\"options\",\"label\":\"Options\",\"type\":\"page\"}],\"promptHierarchies\":[],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"FitStatDelimiter\":{\"value\":\" (Space)\"},\"cutoff\":0.5,\"freq\":[],\"inputTable\":{\"library\":\"\",\"table\":\"\"},\"numBins\":20,\"numCuts\":100,\"pEvent\":null,\"pVars\":[],\"probabilityVariable\":[],\"selectionDepth\":10,\"sensitiveVariable\":[],\"targetEvent\":null,\"targetLevel\":{\"value\":\"Interval\"},\"targetVariable\":[],\"weight\":[]}}","templates":{"SAS":"/* The following program will utilize the P_[ColumnName] Column from a previous\r\n   Step in order to determine if there is a bias in the dataset using PROC ASSESSBIAS*/\r\n\r\n/* Setting up variables for inputTable's libarary and table name */\r\n%let inputTable_lib = &inputTable_lib;\r\n%let inputTable_name = &inputTable_name;\r\n\r\n/* Probability Variable Column Selector */\r\n%let probabilityVariable = &probabilityVariable;\r\n\r\n/* Target Variable Column Selector and Target Level Dropdown*/\r\n/* Target Level Dropdown has the options of only \"Interval\" or \"Nominal\"*/\r\n%let targetVariable = &targetVariable;\r\n%let targetLevel = &targetLevel;\r\n%let targetEvent = &targetEvent;\r\n\r\n/* Sensistive Variable Column Selector */\r\n%let sensitiveVariable = &sensitiveVariable;\r\n\r\n/* Setting up variables in Options section */\r\n%let cutoff = &cutoff;\r\n%let numBins = &numBins;\r\n%let numCuts = &numCuts;\r\n%let selectionDepth = &selectionDepth;\r\n%let weight = &weight;\r\n%let freq = &freq;\r\n\r\n/* Setting up fitStat Variables */\r\n%let pVars = &pVars;\r\n%let pEvent = &pEvent;\r\n%let FitStatDelimiter = &FitStatDelimiter;\r\n\r\n\r\n%macro setDelimiter();\r\n    %global fsDelimiterClean;\r\n\r\n    %if %superq(FitStatDelimiter) = %str(%;) %then %do;\r\n        %let fsDelimiterClean = %str(%;);\r\n    %end;\r\n    %else %if %superq(FitStatDelimiter) = %str(*) %then %do;\r\n        %let fsDelimiterClean = %str(*);\r\n    %end;\r\n    %else %if %superq(FitStatDelimiter) = %str(.) %then %do;\r\n        %let fsDelimiterClean = %str(.);\r\n    %end;\r\n    %else %if %superq(FitStatDelimiter) = %str(,) %then %do;\r\n        %let fsDelimiterClean = %str(,);\r\n    %end;\r\n    %else %do;                /* ← fixed: %do instead of ; */\r\n        %let fsDelimiterClean = %str( );\r\n    %end;\r\n%mend setDelimiter;\r\n\r\n%macro fsIf();\r\n    %if %superq( pVars ) ne and %superq( pEvent ) ne %then %do;\r\n        fitstat pVar=&pVars / pEvent= \"&pEvent\" Delimiter = \"&fsDelimiterClean\";\r\n    %end;\r\n    %else %if %superq( pVars ) ne %then %do;\r\n        fitstat pVar=&pVars;\r\n    %end;\r\n%mend fsIf;\r\n\r\n\r\nproc assessbias \r\ndata=&inputTable_lib..&inputTable_name\r\ncutoff=&cutoff nBins=&numBins \r\nnCuts=&numCuts \r\nselectionDepth=&selectionDepth;\r\n    \r\n      \r\n    /* Input/Probability Variable*/\r\n    var &probabilityVariable;\r\n    \r\n    /* Target Code */\r\n    %if %upcase(&targetLevel)=NOMINAL and %superq(targetEvent) ne %then %do;\r\n        target &targetVariable / event=\"&targetEvent\" level=&targetLevel;\r\n    %end;\r\n    %else %do;\r\n        target &targetVariable;\r\n    %end;    \r\n    \r\n    /*Sensitive Variable */\r\n    sensitivevar &sensitiveVariable;\r\n    \r\n    /* Weight (Optional) */\r\n    %if %superq( weight ) ne %then %do;\r\n        weight &weight;\r\n    %end;\r\n\r\n    /* Frequency */\r\n    %if %superq( freq ) ne %then %do;\r\n        freq &freq;\r\n    %end;\r\n\r\n    \r\n    /* Normalize delimiter value */\r\n    %let fsDelimiterClean=;\r\n\r\n     \r\n    %setDelimiter;\r\n    /*%if %upcase(%superq(FitStatDelimiter)) = %upcase(%str( )) \r\n        or %superq(FitStatDelimiter) = %nrquote(%(Space%)) %then %do;\r\n        %let fsDelimiterClean=%str( );\r\n    %end;  */\r\n\r\n\r\n    *Design for fitstat;  \r\n    %fsIf;\r\n\r\n    *target &targetVar;\r\n    /*fitstat pVar=&pVars / pEvent=&pEvent Delimiter = &fsDelimiter;\r\n    target &targetVar / event = &targetEvent level = &targetLevel;*/\r\nrun;"}}
