{"name": "Auto_Generated_00dcf010-6504-4727-92c1-e771414b420f", "creationTimeStamp": null, "modifiedTimeStamp": null, "createdBy": null, "modifiedBy": null, "displayName": null, "localDisplayName": null, "properties": null, "links": null, "metadataVersion": null, "version": null, "type": "code", "flowMetadata": null, "ui": "{\"showPageContentOnly\": true, \"pages\": [{\"id\": \"config\", \"type\": \"page\", \"label\": \"Configuration\", \"children\": [{\"id\": \"inputTable\", \"type\": \"inputtable\", \"label\": \"Input table\", \"required\": true, \"placeholder\": \"\", \"visible\": \"\", \"filter\": false}, {\"id\": \"probabilityVariable\", \"type\": \"columnselector\", \"label\": \"Predicted Probability Variable\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": null, \"min\": 1, \"visible\": \"\", \"table\": \"inputTable\"}, {\"id\": \"sensitiveVariable\", \"type\": \"columnselector\", \"label\": \"Sensitive Variable\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": 1, \"min\": 1, \"visible\": \"\", \"table\": \"inputTable\"}, {\"id\": \"targetSection\", \"type\": \"section\", \"label\": \"Target\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"targetVariable\", \"type\": \"columnselector\", \"label\": \"Target Variable\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": 1, \"min\": 1, \"visible\": \"\", \"table\": \"inputTable\"}, {\"id\": \"targetLevel\", \"type\": \"dropdown\", \"label\": \"Target Level\", \"items\": [{\"value\": \"Interval\"}, {\"value\": \"Nominal\"}], \"required\": true, \"placeholder\": \"\", \"visible\": [\"$targetVariable\", \"!=\", \"\"]}, {\"id\": \"targetEvent\", \"type\": \"dropdown\", \"label\": \"Target Event\", \"items\": {\"ref\": \"targetVariable\"}, \"required\": false, \"placeholder\": \"\", \"visible\": [\"$targetLevel\", \"=\", \"Nominal\"]}, {\"id\": \"fitStatSection\", \"type\": \"section\", \"label\": \"FitStat\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"pVars\", \"type\": \"columnselector\", \"label\": \"P Variables\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": 1, \"min\": null, \"visible\": \"\", \"table\": \"inputTable\"}, {\"id\": \"pEvent\", \"type\": \"dropdown\", \"label\": \"P Event\", \"items\": {\"ref\": \"targetVariable\"}, \"required\": false, \"placeholder\": \"\", \"visible\": \"\"}, {\"id\": \"FitStatDelimiter\", \"type\": \"dropdown\", \"label\": \"Delimiter\", \"items\": [{\"value\": \" (Space)\"}, {\"value\": \"; (Semicolon)\"}, {\"value\": \"* (Astrisk)\"}, {\"value\": \". (Period)\"}, {\"value\": \", (Comma)\"}], \"required\": true, \"placeholder\": \"\", \"visible\": [\"$pEvent\", \"!=\", \"\"]}]}]}]}, {\"id\": \"options\", \"type\": \"page\", \"label\": \"Options\", \"children\": [{\"id\": \"cutoff\", \"type\": \"numstepper\", \"label\": \"Cutoff Ratio\", \"required\": false, \"integer\": false, \"min\": 0, \"max\": 1, \"stepsize\": 0.1}, {\"id\": \"numBins\", \"type\": \"numstepper\", \"label\": \"Number Of Bins\", \"required\": false, \"integer\": true, \"min\": 2, \"max\": null, \"stepsize\": 1}, {\"id\": \"numCuts\", \"type\": \"numstepper\", \"label\": \"Number Of Cuts\", \"required\": false, \"integer\": true, \"min\": 2, \"max\": 100, \"stepsize\": 1}, {\"id\": \"selectionDepth\", \"type\": \"numstepper\", \"label\": \"Selection Depth\", \"required\": false, \"integer\": true, \"min\": 1, \"max\": 100, \"stepsize\": 1}, {\"id\": \"freq\", \"type\": \"columnselector\", \"label\": \"Frequency\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": 1, \"min\": null, \"visible\": \"\", \"table\": \"inputTable\"}, {\"id\": \"weight\", \"type\": \"columnselector\", \"label\": \"Weight\", \"include\": null, \"order\": false, \"columntype\": \"a\", \"max\": 1, \"min\": null, \"visible\": \"\", \"table\": \"inputTable\"}]}, {\"id\": \"about\", \"type\": \"page\", \"label\": \"About\", \"children\": [{\"id\": \"about_general_text\", \"type\": \"text\", \"text\": \"TAI - Assess Bias\\n===============================\\n\\nThis custom step allows the user to evaluate predictive model bias across sensitive groups using the SAS procedure PROC ASSESSBIAS. The step takes a scored input table (containing a predicted probability column, (P_[ColumnName]) produced by a previous statistical/modeling step) and produces a series of tables that help the user understand fairness in their model:\\n\\nGroup Metrics \\u2014 including number of observations, average squared error, and absolute error per sensitive group.\\nMax Difference Between Sensitive Groups \\u2014 depicting the \\\"worst case\\\" disparity across groups.\\nBias Metrics \\u2014 derived from the group metrics, capturing differences in average prediction, misclassification rate, and related measures.\\n\\nThe closer a bias metric value is to 0, the more similar the treatment was across sensitive groups.\\n\\nMore information about PROC ASSESSBIAS: https://go.documentation.sas.com/doc/en/pgmsascdc/default/casactml/casactml_assessbias_toc.htm\", \"visible\": \"\"}, {\"id\": \"configuration_section\", \"type\": \"section\", \"label\": \"Configuration Tab\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"configuration_text\", \"type\": \"text\", \"text\": \"Input table \\u2014 Select the scored table that contains the predicted probability column, the target variable, and the sensitive variable.\\n\\n\\nPredicted Probability Variable \\u2014 Select one or more probability columns (typically P_[TargetEvent]) generated by an upstream modeling step.\\n\\n\\nSensitive Variable \\u2014 Select exactly one column representing the sensitive grouping (e.g., a PII or demographic variable) on which bias will be assessed.\\n\\n\\nTarget Variable \\u2014 Select the actual target/outcome column.\\nTarget Level \\u2014 Choose Interval or Nominal.\\nTarget Event (visible when Target Level = Nominal) \\u2014 Select the event level of interest from the target variable.\\n\\n\\nP Variables \\u2014 Optional column used in the fitstat statement.\\nP Event \\u2014 Optional event for the FitStat probability variable, referenced from the target variable.\\nDelimiter (visible when P Event is set) \\u2014 Choose the delimiter used by the FitStat statement: Space ( ), Semicolon (;), Asterisk (*),  Period (.), or Comma (,)\", \"visible\": \"\"}]}, {\"id\": \"options_section\", \"type\": \"section\", \"label\": \"Options Tab\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"options_text\", \"type\": \"text\", \"text\": \"Cutoff Ratio \\u2014 Classification cutoff for predicted probabilities (range 0\\u20131, default 0.5).\\n\\n\\nNumber Of Bins \\u2014 Number of bins used for binned bias metrics (min 2, default 20).\\n\\n\\nNumber Of Cuts \\u2014 Number of cutpoints used for cut-based bias metrics (range 2\\u2013100, default 100).\\n\\n\\nSelection Depth \\u2014 Selection depth percentage for depth-based metrics (range 1\\u2013100, default 10).\\n\\n\\nFrequency \\u2014 Optional frequency column.\\n\\n\\nWeight \\u2014 Optional observation weight column.\", \"visible\": \"\"}]}, {\"id\": \"usage_section\", \"type\": \"section\", \"label\": \"Usage\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"usage_text\", \"type\": \"text\", \"text\": \"Required inputs: Input table, Predicted Probability Variable, Sensitive Variable, and Target Variable. If any of these are missing, the step will not execute PROC ASSESSBIAS; instead, an error messege saying \\\"PROC ASSESSBIAS will not run because one or more required variables are missing.\\\"\", \"visible\": \"\"}]}, {\"id\": \"contact_section\", \"type\": \"section\", \"label\": \"Created /Contact\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"created_contact_text\", \"type\": \"text\", \"text\": \"Dawn Pancholi (Shubham.Pancholi@sas.com)\", \"visible\": \"\"}]}, {\"id\": \"version_section\", \"type\": \"section\", \"label\": \"Version\", \"open\": true, \"visible\": \"\", \"children\": [{\"id\": \"version_text\", \"type\": \"text\", \"text\": \"Version : 1.0.0  (19JUN2026)\", \"visible\": \"\"}]}]}], \"syntaxversion\": \"1.3.0\", \"values\": {\"inputTable\": {\"library\": \"\", \"table\": \"\"}, \"probabilityVariable\": [], \"sensitiveVariable\": [], \"targetVariable\": [], \"targetLevel\": {\"value\": \"Interval\"}, \"targetEvent\": null, \"pVars\": [], \"pEvent\": null, \"FitStatDelimiter\": {\"value\": \" (Space)\"}, \"cutoff\": 0.5, \"numBins\": 20, \"numCuts\": 100, \"selectionDepth\": 10, \"freq\": [], \"weight\": []}, \"promptHierarchies\": []}", "templates": {"SAS": "/**/\n\n/* -------------------------------------------------------------------------------------------*\n   TAI - Assess Bias\n\n   v 1.0.0 (19JUN2026)\n\n   This program helps users to check if the model treats different groups fairly by comparing predictions across demographics. \n   Helps identify potential bias in the results.\n\n   Tested in SAS Viya 2026.05\n\n   Dawn Pancholi (Shubham.pancholi@sas.com)\n   \n*-------------------------------------------------------------------------------------------- */\n\n\n/* Setting up variables for inputTable's library and table name */\n%let inputTable_lib = &inputTable_lib.;\n%let inputTable_name = &inputTable_name.;\n\n/* Probability Variable Column Selector */\n%let probabilityVariable = &probabilityVariable.;\n\n/* Target Variable Column Selector and Target Level Dropdown*/\n/* Target Level Dropdown has the options of only \"Interval\" or \"Nominal\"*/\n%let targetVariable = &targetVariable.;\n%let targetLevel = &targetLevel.;\n%let targetEvent = &targetEvent.;\n\n/* Sensistive Variable Column Selector */\n%let sensitiveVariable = &sensitiveVariable.;\n\n/* Setting up variables in Options section */\n%let cutoff = &cutoff.;\n%let numBins = &numBins.;\n%let numCuts = &numCuts.;\n%let selectionDepth = &selectionDepth.;\n%let weight = &weight.;\n%let freq = &freq.;\n\n/* Setting up fitStat Variables */\n%let pVars = &pVars.;\n%let pEvent = &pEvent.;\n%let FitStatDelimiter = &FitStatDelimiter.;\n\n/* Normalize delimiter value */\n%global fsDelimiterClean;\n%let fsDelimiterClean=;\n\n/*************************************************************\n MACRO DEFINITIONS\n*************************************************************/;\n\n/* -----------------------------------------------------------------------------------------* \n   Macro to create an error flag for capture during code execution.\n\n   Input:\n      1. errorFlagName: The name of the error flag you wish to create. Ensure you provide a \n         unique value to this parameter since it will be declared as a global variable.\n      2. errorFlagDesc: A description to add to the error flag.\n\n    Output:\n      1. &errorFlagName : A global variable which takes the name provided to errorFlagName.\n      2. &errorFlagDesc : A global variable which takes the name provided to errorFlagDesc.\n*------------------------------------------------------------------------------------------ */\n%macro _create_error_flag(errorFlagName, errorFlagDesc);\n\n   %global &errorFlagName.;\n   %let  &errorFlagName.=0;\n   %global &errorFlagDesc.;\n\n%mend _create_error_flag;\n\n\n/* Calling the macro to create an error flager */\n%_create_error_flag(_ab_error_flag, _ab_error_desc);\n\n\n\n/* Check Input Table library */\n%if %sysevalf(%superq(inputTable_lib)=, boolean) %then %do;\n   %let _ab_error_flag = 1;\n   %let _ab_error_desc = Input Table has not been specified;\n   %put ERROR: &_ab_error_desc. ;\n%end;\n\n/* Check Input Table name */\n%if %sysevalf(%superq(inputTable_name)=, boolean) %then %do;\n   %let _ab_error_flag = 1;\n   %let _ab_error_desc = Input Table has not been specified;\n   %put ERROR: &_ab_error_desc. ;\n%end;\n\n/* Check Predicted Probability Variable */\n%if %sysevalf(%superq(probabilityVariable)=, boolean) %then %do;\n   %let _ab_error_flag = 1;\n   %let _ab_error_desc = Predicted Probability Variable has not been specified.;\n   %put ERROR: &_ab_error_desc. ;\n%end;\n\n/* Check Target Variable */\n%if %sysevalf(%superq(targetVariable)=, boolean) %then %do;\n   %let _ab_error_flag = 1;\n   %let _ab_error_desc = Target Variable has not been specified.;\n   %put ERROR: &_ab_error_desc. ;\n%end;\n\n/* Check Sensitive Variable */\n%if %sysevalf(%superq(sensitiveVariable)=, boolean) %then %do;\n   %let _ab_error_flag = 1;\n   %let _ab_error_desc = Sensitive Variable has not been specified;\n   %put ERROR: &_ab_error_desc. ;\n%end;\n\n\n/* Macro to determine which delimiter the dropdown in FitStatDelimiter is referring to */\n%macro setDelimiter();\n\n    %if %superq(FitStatDelimiter) = %str(%;) %then %do;\n        %let fsDelimiterClean = %str(%;);\n    %end;\n    %else %if %superq(FitStatDelimiter) = %str(*) %then %do;\n        %let fsDelimiterClean = %str(*);\n    %end;\n    %else %if %superq(FitStatDelimiter) = %str(.) %then %do;\n        %let fsDelimiterClean = %str(.);\n    %end;\n    %else %if %superq(FitStatDelimiter) = %str(,) %then %do;\n        %let fsDelimiterClean = %str(,);\n    %end;\n    %else %do;                /* \u2190 fixed: %do instead of ; */\n        %let fsDelimiterClean = %str( );\n    %end;\n%mend setDelimiter;\n\n/* \n    Macro to determine which fitstat step to do if there's a pEvent and a Delimiter\n    If there is, then use the pEvent and Delimiter add-ons\n    If not, use the base fitstat\n*/\n%macro conditionalFitstat();\n    %if %superq( pVars ) ne and %superq( pEvent ) ne %then %do;\n        fitstat pVar=&pVars / pEvent= \"&pEvent\" Delimiter = \"&fsDelimiterClean\";\n    %end;\n    %else %if %superq( pVars ) ne %then %do;\n        fitstat pVar=&pVars;\n    %end;\n%mend conditionalFitstat;\n\n\n/*\n    Macro to determine direction of execution on the code.\n    If there's a major component missing (specified in the if statements below _create_error_flag) then the if block will execute\n    Otherwise, the else block containing the proc assessbias will execute\n*/\n%macro _ab_guard;\n%if &_ab_error_flag. = 1 %then %do;\n      %put NOTE: PROC ASSESSBIAS will not run because one or more required variables are missing.;\n%end;\n%else %do;\n    proc assessbias data=&inputTable_lib..&inputTable_name cutoff=&cutoff nBins=&numBins nCuts=&numCuts selectionDepth=&selectionDepth;\n        \n        /* Input/Probability Variable*/\n            var &probabilityVariable;\n        \n        /* Target Code */\n            %if %upcase(&targetLevel)=NOMINAL and %superq(targetEvent) ne %then %do;\n                target &targetVariable / event=\"&targetEvent\" level=&targetLevel;\n            %end;\n            %else %do;\n                target &targetVariable;\n            %end;    \n        \n        /*Sensitive Variable */\n            sensitivevar &sensitiveVariable;\n        \n        /* Weight (Optional) */\n            %if %superq( weight ) ne %then %do;\n                weight &weight;\n            %end;\n\n        /* Frequency */\n            %if %superq( freq ) ne %then %do;\n                freq &freq;\n            %end;\n\n         /* Calling the setDelimiter macro to set up the delimiter */\n            %setDelimiter;\n\n        /* Calling the conditionalFitstat macro to determine which fitStat to run */\n            %conditionalFitstat;\n    \n        run;\n%end;\n%mend _ab_guard;\n\n/*************************************************************\n EXECUTION CODE\n*************************************************************/;\n\nTITLE1 \"AssessBias\";\n\n%_ab_guard;"}}