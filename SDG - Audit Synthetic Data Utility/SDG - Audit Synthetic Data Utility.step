{"creationTimeStamp":"2026-07-01T09:26:44.367605Z","createdBy":"albudn","modifiedTimeStamp":"2026-07-01T09:57:29.343404Z","modifiedBy":"albudn","id":"1e013e38-9ea6-4dbc-894d-76ea04b0d867","name":"SDG - Audit Synthetic Data Utility.step","displayName":"SDG - Audit Synthetic Data Utility.step","localDisplayName":"SDG - Audit Synthetic Data Utility.step","links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867/copy","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","uri":"/dataFlows/steps/1e013e38-9ea6-4dbc-894d-76ea04b0d867","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":1,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"realTable","displayName":"realTable","localDisplayName":"realTable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"},{"name":"synthTable","displayName":"synthTable","localDisplayName":"synthTable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}],"outputPorts":[{"name":"summary","displayName":"summary","localDisplayName":"summary","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Controls\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"realTable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Provide real data:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"filter\": false\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"synthTable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Provide synthetic data:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"filter\": false\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"outLib\",\n\t\t\t\t\t\"type\": \"libraryselector\",\n\t\t\t\t\t\"label\": \"Provide output library name:\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"summary\",\n\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\"label\": \"Provide name for the summary table:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"summary table\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"extraTables\",\n\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\"label\": \"Create detail tables for the variables:\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"tablePrefix\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Provide prefix for the output tables:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"filterCondition\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"Filter Condition\",\n\t\t\t\t\t\"include\": null,\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"table\": \"realTable\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"about\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"title1\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Synthetic Data Fidelity & Utility Audit\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"intro_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"This custom step compares a real dataset against a synthetic dataset to produce a composite similarity score. It evaluates data fidelity across four dimensions: numeric univariate similarity (mean, median, standard deviation), categorical univariate similarity (total variation distance and Jensen–Shannon divergence), categorical relationship fidelity (pairwise Cramér's V comparison), and numeric relationship fidelity (pairwise Spearman correlation comparison). Each dimension produces a detail table for drill-through analysis, and the results are combined into weighted statistical and relational similarity scores — proportional to the number of numeric and categorical variables — giving a single overall similarity percentage. An optional filter condition allows evaluation on specific subsets of the data.\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"Parameters\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"Parameters\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"Parameters_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"- Real Table — the two-level name of the real (original) dataset to use as the baseline for comparison (e.g. CASUSER.REAL).\\n- Synthetic Table — the two-level name of the synthetic dataset to evaluate against the real data (e.g. CASUSER.SYNTH).\\n- Filter Condition — an optional WHERE expression to subset both tables before evaluation (e.g. bad=1). Leave blank to run against the full tables.\\n- outLib — the output library where all five result tables will be written (e.g. WORK or CASUSER). Defaults to WORK. \\n- summary table — Always written as similarity_scores in the output library (with any prefix applied). The output port lets you connect downstream flow nodes; the Table node itself is where you'd assign a custom flow name if needed.\\n- Table prefix (optional) — Prefix prepended to all output table names (e.g. q4 produces q4_similarity_scores). Useful when running multiple comparisons in the same library without overwriting previous results.\\n- Create detail tables (checkbox) — When ticked, four detail tables are written to the output library alongside the summary (per-variable and per-pair breakdowns for drill-through analysis). When unticked, only the summary table is kept.\\n\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"References_id\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"References\",\n\t\t\t\t\t\"open\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"References_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"The framework is mentioned in a presentation at SAS Innovate 2026 - watch here: https://www.youtube.com/watch?v=0waLptixaOk&list=PLVBcK_IpFVi-BXicJ5ZMcXuPNQTphJuhv&index=146&t=1s \",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"About\",\n\t\t\t\t\t\"type\": \"section\",\n\t\t\t\t\t\"label\": \"About\",\n\t\t\t\t\t\"open\": true,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"children\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"id\": \"About_text\",\n\t\t\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\t\t\"text\": \"Version: 1.1(1JUL2026)\\n\\nContact: Alina Budnyuk \\n(alina.budnyuk@sas.com)\",\n\t\t\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t\t\t}\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"realTable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"synthTable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"outLib\": \"WORK\",\n\t\t\"summary\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"extraTables\": true,\n\t\t\"tablePrefix\": \"\",\n\t\t\"filterCondition\": []\n\t},\n\t\"promptHierarchies\": []\n}","localUi":"{\"pages\":[{\"children\":[{\"filter\":false,\"id\":\"realTable\",\"label\":\"Provide real data:\",\"placeholder\":\"\",\"required\":true,\"type\":\"inputtable\",\"visible\":\"\"},{\"filter\":false,\"id\":\"synthTable\",\"label\":\"Provide synthetic data:\",\"placeholder\":\"\",\"required\":true,\"type\":\"inputtable\",\"visible\":\"\"},{\"id\":\"outLib\",\"label\":\"Provide output library name:\",\"placeholder\":\"\",\"required\":false,\"type\":\"libraryselector\",\"visible\":\"\"},{\"id\":\"summary\",\"label\":\"Provide name for the summary table:\",\"placeholder\":\"summary table\",\"required\":true,\"type\":\"outputtable\",\"visible\":\"\"},{\"id\":\"extraTables\",\"label\":\"Create detail tables for the variables:\",\"type\":\"checkbox\",\"visible\":\"\"},{\"id\":\"tablePrefix\",\"label\":\"Provide prefix for the output tables:\",\"placeholder\":\"\",\"required\":false,\"type\":\"textfield\",\"visible\":\"\"},{\"columntype\":\"a\",\"id\":\"filterCondition\",\"include\":null,\"label\":\"Filter Condition\",\"max\":null,\"min\":null,\"order\":false,\"table\":\"realTable\",\"type\":\"columnselector\",\"visible\":\"\"}],\"id\":\"page1\",\"label\":\"Controls\",\"type\":\"page\"},{\"children\":[{\"children\":[{\"id\":\"intro_text\",\"text\":\"This custom step compares a real dataset against a synthetic dataset to produce a composite similarity score. It evaluates data fidelity across four dimensions: numeric univariate similarity (mean, median, standard deviation), categorical univariate similarity (total variation distance and Jensen–Shannon divergence), categorical relationship fidelity (pairwise Cramér's V comparison), and numeric relationship fidelity (pairwise Spearman correlation comparison). Each dimension produces a detail table for drill-through analysis, and the results are combined into weighted statistical and relational similarity scores — proportional to the number of numeric and categorical variables — giving a single overall similarity percentage. An optional filter condition allows evaluation on specific subsets of the data.\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"title1\",\"label\":\"Synthetic Data Fidelity \\u0026 Utility Audit\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"Parameters_text\",\"text\":\"- Real Table — the two-level name of the real (original) dataset to use as the baseline for comparison (e.g. CASUSER.REAL).\\n- Synthetic Table — the two-level name of the synthetic dataset to evaluate against the real data (e.g. CASUSER.SYNTH).\\n- Filter Condition — an optional WHERE expression to subset both tables before evaluation (e.g. bad=1). Leave blank to run against the full tables.\\n- outLib — the output library where all five result tables will be written (e.g. WORK or CASUSER). Defaults to WORK. \\n- summary table — Always written as similarity_scores in the output library (with any prefix applied). The output port lets you connect downstream flow nodes; the Table node itself is where you'd assign a custom flow name if needed.\\n- Table prefix (optional) — Prefix prepended to all output table names (e.g. q4 produces q4_similarity_scores). Useful when running multiple comparisons in the same library without overwriting previous results.\\n- Create detail tables (checkbox) — When ticked, four detail tables are written to the output library alongside the summary (per-variable and per-pair breakdowns for drill-through analysis). When unticked, only the summary table is kept.\\n\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"Parameters\",\"label\":\"Parameters\",\"open\":true,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"References_text\",\"text\":\"The framework is mentioned in a presentation at SAS Innovate 2026 - watch here: https://www.youtube.com/watch?v=0waLptixaOk\\u0026list=PLVBcK_IpFVi-BXicJ5ZMcXuPNQTphJuhv\\u0026index=146\\u0026t=1s \",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"References_id\",\"label\":\"References\",\"open\":false,\"type\":\"section\",\"visible\":\"\"},{\"children\":[{\"id\":\"About_text\",\"text\":\"Version: 1.1(1JUL2026)\\n\\nContact: Alina Budnyuk \\n(alina.budnyuk@sas.com)\",\"type\":\"text\",\"visible\":\"\"}],\"id\":\"About\",\"label\":\"About\",\"open\":true,\"type\":\"section\",\"visible\":\"\"}],\"id\":\"about\",\"label\":\"About\",\"type\":\"page\"}],\"promptHierarchies\":[],\"showPageContentOnly\":true,\"syntaxversion\":\"1.3.0\",\"values\":{\"extraTables\":true,\"filterCondition\":[],\"outLib\":\"WORK\",\"realTable\":{\"library\":\"\",\"table\":\"\"},\"summary\":{\"library\":\"\",\"table\":\"\"},\"synthTable\":{\"library\":\"\",\"table\":\"\"},\"tablePrefix\":\"\"}}","templates":{"SAS":"/*============================================================\r\n  SYNTHETIC DATA COMPARISON — Custom Step Macro\r\n  ============================================================\r\n  PURPOSE\r\n    Compare a real table against a synthetic table across\r\n    four evaluation dimensions and produce a composite\r\n    similarity score.\r\n\r\n  VERSION\r\n    1.0 (11JUN2026)\r\n\r\n  DIMENSIONS\r\n    1. Numeric Univariate    — mean / median / std comparison\r\n    2. Categorical Univariate — TVD + JSD on category frequencies\r\n    3. Categorical Relationship — pairwise Cramér's V delta\r\n    4. Numeric Relationship    — pairwise Spearman ρ delta\r\n\r\n  PARAMETERS\r\n    realTable        Two-level name of real dataset\r\n    synthTable       Two-level name of synthetic dataset\r\n    filterCondition  Optional WHERE expression\r\n    outLib           Output library (default WORK)\r\n    summary          Summary output table name (default similarity_scores)\r\n    tablePrefix      Optional prefix prepended to output table names\r\n    extraTables      1/0 — also write the four detail tables (default 1)\r\n\r\n  OUTPUT TABLES (written to &outLib.)\r\n    <prefix_>similarity_scores               (always)\r\n    <prefix_>detail_num_univariate           (only if extraTables=1)\r\n    <prefix_>detail_cat_univariate           (only if extraTables=1)\r\n    <prefix_>detail_cat_relationship         (only if extraTables=1)\r\n    <prefix_>detail_num_relationship         (only if extraTables=1)\r\n============================================================*/\r\n\r\n/*********************************************\r\n  MACRO DEFINITION\r\n*********************************************/\r\n\r\n%macro syntheticDataComparison(\r\n    realTable       = ,\r\n    synthTable      = ,\r\n    filterCondition = ,\r\n    outLib          = WORK,\r\n    summary         = ,\r\n    tablePrefix     = ,\r\n    extraTables     = 1\r\n);\r\n\r\n    /* ============================================================\r\n       0.  SETUP\r\n       ============================================================ */\r\n    %local wc char_vars num_vars nChar nNum i var prefix\r\n           sc_numUni sc_catUni sc_catRel sc_numRel\r\n           tbl_summary tbl_numUni tbl_catUni tbl_catRel tbl_numRel\r\n           writeDetails _sumLib _sumName _sumVal;\r\n\r\n    options nosyntaxcheck;\r\n\r\n    /* --- reusable WHERE-clause dataset option --- */\r\n    %if %length(&filterCondition.) > 0 %then\r\n        %let wc = (where=(&filterCondition.));\r\n    %else\r\n        %let wc = ;\r\n\r\n    /* --- optional prefix --- */\r\n    %if %length(&tablePrefix.) > 0 %then\r\n        %let prefix = &tablePrefix._;\r\n    %else\r\n        %let prefix = ;\r\n\r\n    /* --- summary table: ignore SAS Studio's auto-generated placeholder\r\n           names (containing \"_FLW\") so the default applies --- */\r\n    %let _sumVal = &summary.;\r\n    %if %index(%upcase(&_sumVal.), _FLW) > 0 %then\r\n        %let _sumVal = ;\r\n\r\n    %if %length(&_sumVal.) = 0 %then %do;\r\n        %let _sumLib  = &outLib.;\r\n        %let _sumName = similarity_scores;\r\n    %end;\r\n    %else %if %index(&_sumVal., .) > 0 %then %do;\r\n        %let _sumLib  = %scan(&_sumVal., 1, .);\r\n        %let _sumName = %scan(&_sumVal., 2, .);\r\n    %end;\r\n    %else %do;\r\n        %let _sumLib  = &outLib.;\r\n        %let _sumName = &_sumVal.;\r\n    %end;\r\n    %let tbl_summary = &_sumLib..&prefix.&_sumName.;\r\n\r\n    /* --- detail tables always use the standard name in outLib + prefix --- */\r\n    %let tbl_numUni = &outLib..&prefix.detail_num_univariate;\r\n    %let tbl_catUni = &outLib..&prefix.detail_cat_univariate;\r\n    %let tbl_catRel = &outLib..&prefix.detail_cat_relationship;\r\n    %let tbl_numRel = &outLib..&prefix.detail_num_relationship;\r\n\r\n    /* --- decide whether to keep the detail tables after the run --- */\r\n    %let writeDetails = 0;\r\n    %if %symexist(extraTables) %then %do;\r\n        %if &extraTables. = 1 %then %let writeDetails = 1;\r\n    %end;\r\n    %else %do;\r\n        %let writeDetails = 1;\r\n    %end;\r\n\r\n    /* --- discover character variables --- */\r\n    proc sql noprint;\r\n        select name into :char_vars separated by ' '\r\n        from dictionary.columns\r\n        where libname = upcase(scan(\"&realTable.\", 1, '.'))\r\n          and memname = upcase(scan(\"&realTable.\", 2, '.'))\r\n          and type    = 'char';\r\n    quit;\r\n    %let nChar = %sysfunc(countw(&char_vars.));\r\n\r\n    /* --- discover numeric variables --- */\r\n    proc sql noprint;\r\n        select name into :num_vars separated by ' '\r\n        from dictionary.columns\r\n        where libname = upcase(scan(\"&realTable.\", 1, '.'))\r\n          and memname = upcase(scan(\"&realTable.\", 2, '.'))\r\n          and type    = 'num';\r\n    quit;\r\n    %let nNum = %sysfunc(countw(&num_vars.));\r\n\r\n    /* initialise component scores to missing */\r\n    %let sc_numUni = .;\r\n    %let sc_catUni = .;\r\n    %let sc_catRel = .;\r\n    %let sc_numRel = .;\r\n\r\n\r\n    /* ============================================================\r\n       1.  NUMERIC UNIVARIATE SIMILARITY\r\n       ============================================================ */\r\n    %if &nNum. > 0 %then %do;\r\n\r\n        proc means data=&realTable.&wc. noprint;\r\n            var &num_vars.;\r\n            output out=_nv_real mean= median= std= / autoname;\r\n        run;\r\n\r\n        proc means data=&synthTable.&wc. noprint;\r\n            var &num_vars.;\r\n            output out=_nv_fake mean= median= std= / autoname;\r\n        run;\r\n\r\n        proc transpose data=_nv_real(drop=_TYPE_ _FREQ_)\r\n             out=_nv_real_t(rename=(_NAME_=statistic col1=real_value));\r\n        run;\r\n        proc transpose data=_nv_fake(drop=_TYPE_ _FREQ_)\r\n             out=_nv_fake_t(rename=(_NAME_=statistic col1=fake_value));\r\n        run;\r\n\r\n        proc sort data=_nv_real_t; by statistic; run;\r\n        proc sort data=_nv_fake_t; by statistic; run;\r\n\r\n        data &tbl_numUni;\r\n            merge _nv_real_t _nv_fake_t;\r\n            by statistic;\r\n\r\n            length variable $32 stat_type $10;\r\n            stat_type = scan(statistic, -1, '_');\r\n            variable  = substr(statistic, 1,\r\n                          length(statistic) - length(stat_type) - 1);\r\n\r\n            denom          = max(abs(real_value), abs(fake_value), 1);\r\n            pct_similarity = 100 - 100 * abs(real_value - fake_value) / denom;\r\n\r\n            drop denom;\r\n        run;\r\n\r\n        proc means data=&tbl_numUni noprint;\r\n            var pct_similarity;\r\n            output out=_nv_agg mean=_mean;\r\n        run;\r\n\r\n        data _null_;\r\n            set _nv_agg;\r\n            call symputx('sc_numUni', _mean / 100);\r\n        run;\r\n\r\n    %end;\r\n\r\n\r\n    /* ============================================================\r\n       2.  CATEGORICAL UNIVARIATE SIMILARITY\r\n       ============================================================ */\r\n    %if &nChar. > 0 %then %do;\r\n\r\n        %do i = 1 %to &nChar.;\r\n            %let var = %scan(&char_vars., &i.);\r\n\r\n            proc freq data=&realTable.&wc. noprint;\r\n                tables &var. / out=_cf_r_&i.;\r\n            run;\r\n\r\n            data _cf_r_&i.(keep=varname category PERCENT);\r\n                length varname $32 category $256;\r\n                set _cf_r_&i.;\r\n                varname  = \"&var.\";\r\n                category = strip(&var.);\r\n            run;\r\n        %end;\r\n\r\n        data _cf_real;\r\n            set %do i = 1 %to &nChar.; _cf_r_&i. %end;;\r\n        run;\r\n\r\n        %do i = 1 %to &nChar.;\r\n            %let var = %scan(&char_vars., &i.);\r\n\r\n            proc freq data=&synthTable.&wc. noprint;\r\n                tables &var. / out=_cf_s_&i.;\r\n            run;\r\n\r\n            data _cf_s_&i.(keep=varname category PERCENT);\r\n                length varname $32 category $256;\r\n                set _cf_s_&i.;\r\n                varname  = \"&var.\";\r\n                category = strip(&var.);\r\n            run;\r\n        %end;\r\n\r\n        data _cf_fake;\r\n            set %do i = 1 %to &nChar.; _cf_s_&i. %end;;\r\n        run;\r\n\r\n        proc sort data=_cf_real; by varname category; run;\r\n        proc sort data=_cf_fake; by varname category; run;\r\n\r\n        data _cf_merged;\r\n            merge _cf_real(rename=(PERCENT=real_pct))\r\n                  _cf_fake(rename=(PERCENT=fake_pct));\r\n            by varname category;\r\n\r\n            real_p = coalesce(real_pct, 0) / 100;\r\n            fake_p = coalesce(fake_pct, 0) / 100;\r\n\r\n            tvd_i = abs(real_p - fake_p);\r\n\r\n            M = (real_p + fake_p) / 2;\r\n\r\n            if real_p > 0 and M > 0 then kl_r = real_p * log2(real_p / M);\r\n            else kl_r = 0;\r\n\r\n            if fake_p > 0 and M > 0 then kl_f = fake_p * log2(fake_p / M);\r\n            else kl_f = 0;\r\n        run;\r\n\r\n        proc means data=_cf_merged noprint;\r\n            by varname;\r\n            var tvd_i kl_r kl_f;\r\n            output out=_cf_summary\r\n                sum(tvd_i) = tvd_raw\r\n                sum(kl_r)  = kl_real\r\n                sum(kl_f)  = kl_fake;\r\n        run;\r\n\r\n        data &tbl_catUni(keep=varname TVD JSD);\r\n            set _cf_summary;\r\n            JSD = sqrt(0.5 * (kl_real + kl_fake));\r\n            TVD = 0.5 * tvd_raw;\r\n        run;\r\n\r\n        proc means data=&tbl_catUni mean max noprint;\r\n            var TVD JSD;\r\n            output out=_cf_agg\r\n                mean = Mean_TVD Mean_JSD\r\n                max  = Max_TVD  Max_JSD;\r\n        run;\r\n\r\n        data _null_;\r\n            set _cf_agg;\r\n            _tvd = mean((1 - Mean_TVD), (1 - Max_TVD));\r\n            _jsd = mean((1 - Mean_JSD), (1 - Max_JSD));\r\n            call symputx('sc_catUni', mean(_tvd, _jsd));\r\n        run;\r\n\r\n    %end;\r\n\r\n\r\n    /* ============================================================\r\n       3.  CATEGORICAL RELATIONSHIP FIDELITY (Cramér's V)\r\n       ============================================================ */\r\n    %if &nChar. >= 2 %then %do;\r\n\r\n        ods exclude all;\r\n        proc freq data=&realTable.&wc.;\r\n            tables (&char_vars.) * (&char_vars.) / chisq;\r\n            ods output ChiSq = _cv_real_chi;\r\n        run;\r\n        ods exclude none;\r\n\r\n        data _cv_real(keep=Var1 Var2 Real_V);\r\n            length Var1 Var2 $32;\r\n            set _cv_real_chi(where=(statistic = \"Cramer's V\"));\r\n            Var1   = scan(table, 2, ' ');\r\n            Var2   = scan(table, 4, ' ');\r\n            Real_V = value;\r\n            if Var1 < Var2;\r\n        run;\r\n\r\n        ods exclude all;\r\n        proc freq data=&synthTable.&wc.;\r\n            tables (&char_vars.) * (&char_vars.) / chisq;\r\n            ods output ChiSq = _cv_fake_chi;\r\n        run;\r\n        ods exclude none;\r\n\r\n        data _cv_fake(keep=Var1 Var2 Fake_V);\r\n            length Var1 Var2 $32;\r\n            set _cv_fake_chi(where=(statistic = \"Cramer's V\"));\r\n            Var1   = scan(table, 2, ' ');\r\n            Var2   = scan(table, 4, ' ');\r\n            Fake_V = value;\r\n            if Var1 < Var2;\r\n        run;\r\n\r\n        proc sort data=_cv_real; by Var1 Var2; run;\r\n        proc sort data=_cv_fake; by Var1 Var2; run;\r\n\r\n        data &tbl_catRel;\r\n            merge _cv_real _cv_fake;\r\n            by Var1 Var2;\r\n            if Real_V = . then Real_V = 0;\r\n            if Fake_V = . then Fake_V = 0;\r\n            Abs_Delta = abs(Real_V - Fake_V);\r\n        run;\r\n\r\n        proc means data=&tbl_catRel noprint;\r\n            var Abs_Delta;\r\n            output out=_cv_agg mean=_mean;\r\n        run;\r\n\r\n        data _null_;\r\n            set _cv_agg;\r\n            call symputx('sc_catRel', 1 - _mean);\r\n        run;\r\n\r\n    %end;\r\n\r\n\r\n    /* ============================================================\r\n       4.  NUMERIC RELATIONSHIP FIDELITY (Spearman)\r\n       ============================================================ */\r\n    %if &nNum. >= 2 %then %do;\r\n\r\n        proc corr data=&realTable.&wc. spearman noprint outp=_sp_real;\r\n            var &num_vars.;\r\n        run;\r\n        proc corr data=&synthTable.&wc. spearman noprint outp=_sp_fake;\r\n            var &num_vars.;\r\n        run;\r\n\r\n        data _sp_real_long(keep=Var1 Var2 Real_Corr);\r\n            set _sp_real(where=(_TYPE_ = 'CORR'));\r\n            array v {*} &num_vars.;\r\n            length Var1 Var2 $32;\r\n            Var1 = _NAME_;\r\n            do _j = 1 to dim(v);\r\n                Var2      = vname(v[_j]);\r\n                Real_Corr = v[_j];\r\n                if Var1 < Var2 then output;\r\n            end;\r\n        run;\r\n\r\n        data _sp_fake_long(keep=Var1 Var2 Fake_Corr);\r\n            set _sp_fake(where=(_TYPE_ = 'CORR'));\r\n            array v {*} &num_vars.;\r\n            length Var1 Var2 $32;\r\n            Var1 = _NAME_;\r\n            do _j = 1 to dim(v);\r\n                Var2      = vname(v[_j]);\r\n                Fake_Corr = v[_j];\r\n                if Var1 < Var2 then output;\r\n            end;\r\n        run;\r\n\r\n        proc sort data=_sp_real_long; by Var1 Var2; run;\r\n        proc sort data=_sp_fake_long; by Var1 Var2; run;\r\n\r\n        data &tbl_numRel;\r\n            merge _sp_real_long _sp_fake_long;\r\n            by Var1 Var2;\r\n            if Real_Corr = . then Real_Corr = 0;\r\n            if Fake_Corr = . then Fake_Corr = 0;\r\n            Abs_Delta = min(abs(Real_Corr - Fake_Corr), 1.0);\r\n        run;\r\n\r\n        proc means data=&tbl_numRel noprint;\r\n            var Abs_Delta;\r\n            output out=_sp_agg mean=_mean;\r\n        run;\r\n\r\n        data _null_;\r\n            set _sp_agg;\r\n            call symputx('sc_numRel', 1 - _mean);\r\n        run;\r\n\r\n    %end;\r\n\r\n\r\n    /* ============================================================\r\n       5.  FINAL SIMILARITY SCORES\r\n       ============================================================ */\r\n    data &tbl_summary;\r\n        format overall_similarity_pct\r\n               statistical_similarity_pct\r\n               relational_similarity_pct\r\n               num_similarity_pct\r\n               char_similarity_pct\r\n               char_corr_pct\r\n               num_corr_pct percent10.3;\r\n\r\n        num_similarity_pct  = &sc_numUni.;\r\n        char_similarity_pct = &sc_catUni.;\r\n        char_corr_pct       = &sc_catRel.;\r\n        num_corr_pct        = &sc_numRel.;\r\n\r\n        _nw = ifn(num_similarity_pct  = ., 0, &nNum.);\r\n        _cw = ifn(char_similarity_pct = ., 0, &nChar.);\r\n\r\n        if (_nw + _cw) > 0 then\r\n            statistical_similarity_pct =\r\n                (_nw * num_similarity_pct + _cw * char_similarity_pct)\r\n                / (_nw + _cw);\r\n        else\r\n            statistical_similarity_pct = .;\r\n\r\n        _nw_r = ifn(num_corr_pct  = ., 0, &nNum.);\r\n        _cw_r = ifn(char_corr_pct = ., 0, &nChar.);\r\n\r\n        if (_nw_r + _cw_r) > 0 then\r\n            relational_similarity_pct =\r\n                (_nw_r * num_corr_pct + _cw_r * char_corr_pct)\r\n                / (_nw_r + _cw_r);\r\n        else\r\n            relational_similarity_pct = .;\r\n\r\n        overall_similarity_pct = mean(\r\n            statistical_similarity_pct,\r\n            relational_similarity_pct\r\n        );\r\n\r\n        drop _nw _cw _nw_r _cw_r;\r\n    run;\r\n\r\n\r\n    /* ============================================================\r\n       CLEANUP\r\n       Always remove intermediate WORK tables.\r\n       If extraTables=0, also remove the four detail tables.\r\n       ============================================================ */\r\n    proc datasets lib=WORK nolist nowarn;\r\n        delete\r\n            _nv_real _nv_fake _nv_real_t _nv_fake_t _nv_agg\r\n            _cf_r_: _cf_s_: _cf_real _cf_fake _cf_merged\r\n            _cf_summary _cf_agg\r\n            _cv_real_chi _cv_fake_chi _cv_real _cv_fake _cv_agg\r\n            _sp_real _sp_fake _sp_real_long _sp_fake_long _sp_agg\r\n        ;\r\n    quit;\r\n\r\n    %if &writeDetails. = 0 %then %do;\r\n        proc datasets lib=&outLib. nolist nowarn;\r\n            delete &prefix.detail_num_univariate\r\n                   &prefix.detail_cat_univariate\r\n                   &prefix.detail_cat_relationship\r\n                   &prefix.detail_num_relationship;\r\n        quit;\r\n    %end;\r\n\r\n\r\n    %put NOTE: =====================================================;\r\n    %put NOTE: Synthetic Data Comparison Complete                    ;\r\n    %put NOTE: Num Univar   : &sc_numUni.                           ;\r\n    %put NOTE: Cat Univar   : &sc_catUni.                           ;\r\n    %put NOTE: Cat Relation : &sc_catRel.                           ;\r\n    %put NOTE: Num Relation : &sc_numRel.                           ;\r\n    %put NOTE: Output lib   : &outLib.                              ;\r\n    %put NOTE: Detail tables: %sysfunc(ifc(&writeDetails.=1, kept, removed));\r\n    %put NOTE: =====================================================;\r\n\r\n%mend syntheticDataComparison;\r\n\r\n\r\n/*********************************************\r\n  EXECUTION CODE\r\n*********************************************/\r\n\r\n%syntheticDataComparison(\r\n    realTable       = &realTable,\r\n    synthTable      = &synthTable,\r\n    filterCondition = &filterCondition,\r\n    outLib          = &outLib,\r\n    summary         = &summary,\r\n    tablePrefix     = &tablePrefix,\r\n    extraTables     = &extraTables\r\n);\r\n\r\n\r\n/*********************************************\r\n  CLEAN UP\r\n*********************************************/\r\n\r\n%sysmacdelete syntheticDataComparison / nowarn;\r\n\r\n%symdel\r\n    realTable\r\n    synthTable\r\n    filterCondition\r\n    outLib\r\n    summary\r\n    tablePrefix\r\n    extraTables\r\n    / nowarn\r\n;"}}
